{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Boing Network Hub",
  "version": "0.1.18",
  "identifier": "network.boing.hub",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Boing Network Hub",
        "url": "/app",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "visible": false,
        "decorations": true
      },
      {
        "label": "splashscreen",
        "title": "Boing Network Hub",
        "url": "/splash",
        "width": 420,
        "height": 320,
        "resizable": false,
        "center": true,
        "visible": true,
        "decorations": false,
        "transparent": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com"
    },
    "longDescription": "All-in-one desktop hub for the Boing Network ecosystem: Observer (block explorer), Express (wallet), and Finance (DEX).",
    "shortDescription": "Boing Network desktop hub",
    "category": "Finance",
    "copyright": "",
    "licenseFile": null,
    "resources": [],
    "externalBin": [],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDEzRDM3QTMzNTA1RjM3RTUKUldUbE4xOVFNM3JURTVPNS9PVTRPNEkzNzFxdlZYUll0WXBBR3NTL3J2QmRHWkdVcFZSbUtQWU4K",
      "endpoints": [
        "https://boing.network/hub-updater/latest.json",
        "https://github.com/chiku524/boing.network/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}

{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Boing Network Hub",
  "version": "0.1.0",
  "identifier": "network.boing.hub",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Boing Network Hub",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "longDescription": "All-in-one desktop hub for the Boing Network ecosystem: Observer (block explorer), Express (wallet), and Finance (DEX).",
    "shortDescription": "Boing Network desktop hub",
    "category": "Finance",
    "copyright": "",
    "licenseFile": null,
    "resources": [],
    "externalBin": []
  },
  "plugins": {
    "shell": {
      "open": true,
      "scope": [
        { "name": "open", "cmd": "open", "args": true }
      ]
    }
  }
}

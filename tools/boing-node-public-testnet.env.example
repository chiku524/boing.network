# Copy or merge into your process manager (systemd, Docker, shell) for **public Boing testnet** JSON-RPC.
# `boing_getNetworkInfo` returns `chain_id` / `chain_name` from these variables.
#
# Canonical testnet chain id (same as wallet `boing_chainId` 0x1b01): docs/RPC-API-SPEC.md, docs/TESTNET.md

BOING_CHAIN_ID=6913
BOING_CHAIN_NAME=Boing Testnet

# Optional: strict JSON-RPC rate profile (default without BOING_RATE_PROFILE is mainnet-style).
# BOING_RATE_PROFILE=mainnet

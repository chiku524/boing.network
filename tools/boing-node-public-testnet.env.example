# Copy or merge into your process manager (systemd, Docker, shell) for **public Boing testnet** JSON-RPC.
# `boing_getNetworkInfo` returns `chain_id` / `chain_name` from these variables.
# Ready-made wiring: boing-node-public-testnet.systemd.example, boing-node-public-testnet.docker-compose.yml,
# boing-node-public-testnet.kubernetes.example.yaml (same repo tools/).
#
# Canonical testnet chain id (same as wallet `boing_chainId` 0x1b01): docs/RPC-API-SPEC.md, docs/TESTNET.md

BOING_CHAIN_ID=6913
BOING_CHAIN_NAME=Boing Testnet

# Optional: publish canonical native DEX contract AccountIds for dApps (boing_getNetworkInfo.end_user).
# 64 hex chars each, optional 0x prefix. See docs/RPC-API-SPEC.md, docs/RUNBOOK.md.
# BOING_CANONICAL_NATIVE_CP_POOL=0xce4f819369630e89c4634112fdf01e1907f076bc30907f0402591abfca66518d
# BOING_CANONICAL_NATIVE_DEX_FACTORY=0x12dff97625620a1f10c05cd66cd72878288e8fea70d4150e9815bd38983b2890
# --- DEX L1 discovery tuning (optional; matches node built-in defaults when omitted) ---
# See docs/RPC-API-SPEC.md § boing_listDexPools / boing_listDexTokens. Public RPC: set explicitly so behavior is obvious in `systemctl show` / compose files.
# Recent blocks (newest-first) scanned for ContractDeployWithPurposeAndMetadata symbol/name on listDexTokens / getDexToken (max 500000).
BOING_DEX_TOKEN_METADATA_SCAN_BLOCKS=8192
# Cap receipt rows examined per discovery RPC for factory Log3 register heights (createdAtHeight / firstSeenHeight). 0 = unlimited (operator discretion).
BOING_DEX_DISCOVERY_MAX_RECEIPT_SCANS=500000
# JSON object: "0x" + 64 hex (token AccountId) -> decimals 0–255. {} defers to default 18 for every token; add keys for non-18 canonical assets.
BOING_DEX_TOKEN_DECIMALS_JSON={}
# BOING_CANONICAL_NATIVE_DEX_MULTIHOP_SWAP_ROUTER=0x8f8b2ecb6fd5dc7682e41ebe443d6116e0f4ae8247f67b4bfafec4dea2d861a3
# BOING_CANONICAL_NATIVE_DEX_LEDGER_ROUTER_V2=0x60a232b91d6f86a61d037ea6ea0fb769897f983c8e0d399e3df5189d00868992
# BOING_CANONICAL_NATIVE_DEX_LEDGER_ROUTER_V3=0xfb552619b27dacacba52b62d97cd171eabe4a74dac262ecb0e8735284d7555ba
# BOING_CANONICAL_NATIVE_AMM_LP_VAULT=0x2b195b93a57b632ca3c1cf58cb7578542a6d58998116cddb8a6a50f1bd652f48
# BOING_CANONICAL_NATIVE_LP_SHARE_TOKEN=0x0618b4a6a30bc31822a0cdcf253ed2bcf642a6cecf26346ba655b63fccbde03c

# Optional (dApps / scripts — not read by boing-node): Cloudflare Worker origin for native DEX indexer D1 directory API.
# See docs/HANDOFF_NATIVE_DEX_DIRECTORY_R2_AND_CHAIN.md; boing-sdk nativeDexDirectoryApi.ts; npm run verify-native-dex-directory-worker
# BOING_NATIVE_DEX_DIRECTORY_BASE_URL=https://boing-native-dex-indexer.example.workers.dev

# Optional: strict JSON-RPC rate profile (default without BOING_RATE_PROFILE is mainnet-style).
# BOING_RATE_PROFILE=mainnet

# Large bytecode dumps for tutorial deploy scripts (regenerate: cargo run -p boing-execution --example dump_native_amm_pool / dump_native_dex_factory)
examples/native-boing-tutorial/pool-lines.hex
examples/native-boing-tutorial/dex-factory.hex

# Cursor IDE (local)
.cursor/

# Dependencies
node_modules/

# Build outputs (boing-sdk/dist is tracked so file:/npm consumers resolve dist/ on clone)
dist/
!boing-sdk/dist/
!boing-sdk/dist/**
website/dist/
target/

# Local dev / Wrangler
.wrangler/
website/.env
.astro/

# Windows reserved device name (accidental file)
nul
NUL

# Cloudflare tunnel binary (local)
.cloudflared/

# Tauri updater signing key (never commit; pubkey lives in tauri.conf.json)
desktop-hub/.tauri/

# Tauri CLI generated schemas (regenerated on build)
desktop-hub/src-tauri/gen/

# TypeScript / Vite emit artifacts (local)
desktop-hub/*.tsbuildinfo
desktop-hub/vite.config.js
desktop-hub/vite.config.d.ts

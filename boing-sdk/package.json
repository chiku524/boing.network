{
  "name": "boing-sdk",
  "version": "0.1.0",
  "description": "Seamless SDK for building on Boing Network",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc && node -e \"console.log('boing-sdk: TypeScript compiled to dist/ (ok)')\"",
    "dev": "tsc --watch",
    "test": "vitest run",
    "verify": "node scripts/verify.mjs",
    "embed-fungible-hex": "node scripts/embed-reference-fungible-template-hex.mjs",
    "probe-rpc": "node scripts/probe-rpc.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "boing",
    "blockchain",
    "sdk"
  ],
  "license": "MIT",
  "dependencies": {
    "@noble/hashes": "^1.6.0",
    "@noble/ed25519": "^2.2.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "vitest": "^2.1.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  }
}
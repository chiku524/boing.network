---
/**
 * Genesis Block cinematic intro for Boing Network.
 * Aligns with boing-cinematic-intros/STORYBOARDS.md "boing.network — Genesis Block":
 *   The Void → Approach → Arrival (hexagon) → Genesis Pulse → Network Formation → Seamless Transition.
 * Core principles: ~3–4s duration, skippable, seamless dissolve into live background, plot-driven, CSS + minimal JS.
 * Integration: intro at z-index 100; timing in T object; skip triggers dismiss.
 */
interface Props {
  /** Total duration in ms. Storyboard: ~4s. */
  durationMs?: number;
}

const { durationMs = 4000 } = Astro.props;
---

<div class="intro-overlay" id="genesis-intro-overlay" aria-hidden="true" data-duration={durationMs}>
  <button type="button" class="intro-skip" id="genesis-skip-btn" aria-label="Skip intro">Skip ›</button>
  <canvas id="genesis-intro-canvas" class="intro-canvas" aria-hidden="true"></canvas>
  <div id="genesis-scene-text" class="intro-scene-text" aria-hidden="true"></div>
  <div id="genesis-progress-bar" class="intro-progress-bar" aria-hidden="true"></div>
</div>

<script define:vars={{ durationMs }}>
  (function () {
    const overlay = document.getElementById('genesis-intro-overlay');
    if (!overlay) return;

    const TOTAL = durationMs;
    const scale = TOTAL / 5000; // storyboard reference 5s → scale to durationMs
    const VIO_R = 124, VIO_G = 58, VIO_B = 237;
    const CYN_R = 6, CYN_G = 182, CYN_B = 212;
    const DEEP_BG = '#020408';

    const canvas = document.getElementById('genesis-intro-canvas');
    const ctx = canvas?.getContext('2d');
    const sceneText = document.getElementById('genesis-scene-text');
    const progressBar = document.getElementById('genesis-progress-bar');
    const skipBtn = document.getElementById('genesis-skip-btn');

    const bgWrap = document.querySelector('.boing-canvas-bg');

    let W, H, raf, startTime, done = false, textShown = false;

    const T = {
      flyStart: 0,
      arrivalStart: Math.round(1800 * scale),
      arrivalPeak: Math.round(2400 * scale),
      hexReveal: Math.round(2200 * scale),
      hexGlow: Math.round(2600 * scale),
      genesisPulse: Math.round(3000 * scale),
      shockwaveEnd: Math.round(4000 * scale),
      textShow: Math.round(3400 * scale),
      outroStart: Math.round(4000 * scale),
      end: TOTAL,
    };

    function resize() {
      W = canvas.width = window.innerWidth;
      H = canvas.height = window.innerHeight;
    }
    function easeOut(t) { return 1 - Math.pow(1 - t, 3); }
    function easeIn(t) { return t * t * t; }
    function easeInOut(t) { return t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2; }
    function clamp(v, a, b) { return Math.max(a, Math.min(b, v)); }
    function lerp(a, b, t) { return a + (b - a) * t; }
    function invLerp(a, b, v) { return clamp((v - a) / (b - a), 0, 1); }
    function range(t0, t1, t) { return easeInOut(invLerp(t0, t1, t)); }

    const STAR_COUNT = 200;
    const stars = Array.from({ length: STAR_COUNT }, () => {
      const angle = Math.random() * Math.PI * 2;
      const dist = 0.02 + Math.random() * 0.98;
      return {
        angle, dist,
        size: 0.4 + Math.random() * 1.5,
        brightness: 0.15 + Math.random() * 0.7,
        twinklePhase: Math.random() * Math.PI * 2,
        color: Math.random() > 0.85 ? `rgba(${VIO_R},${VIO_G},${VIO_B},1)` : '#e8e8ff',
      };
    });

    function drawStarField(warpProgress, t) {
      if (!ctx) return;
      ctx.save();
      const cx = W / 2, cy = H / 2;
      const maxR = Math.hypot(W, H) * 0.6;
      stars.forEach(s => {
        const r = s.dist * maxR;
        const x = cx + Math.cos(s.angle) * r;
        const y = cy + Math.sin(s.angle) * r;
        const warpLen = warpProgress * r * 0.35;
        const sx = cx + Math.cos(s.angle) * (r - warpLen);
        const sy = cy + Math.sin(s.angle) * (r - warpLen);
        const twinkle = s.brightness + 0.12 * Math.sin(t * 0.001 + s.twinklePhase);
        const alpha = clamp(twinkle, 0, 1);
        if (warpProgress > 0.05) {
          ctx.save();
          ctx.globalAlpha = alpha * 0.7;
          ctx.strokeStyle = s.color;
          ctx.lineWidth = s.size * 0.6;
          ctx.beginPath();
          ctx.moveTo(sx, sy);
          ctx.lineTo(x, y);
          ctx.stroke();
          ctx.restore();
        } else {
          ctx.save();
          ctx.globalAlpha = alpha;
          ctx.fillStyle = s.color;
          ctx.beginPath();
          ctx.arc(x, y, s.size, 0, Math.PI * 2);
          ctx.fill();
          ctx.restore();
        }
      });
      ctx.restore();
    }

    function hexPath(cx, cy, r, rotation) {
      if (!ctx) return;
      ctx.beginPath();
      for (let i = 0; i < 6; i++) {
        const a = rotation + (i * Math.PI) / 3;
        const x = cx + r * Math.cos(a);
        const y = cy + r * Math.sin(a);
        i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
      }
      ctx.closePath();
    }

    function drawHex(cx, cy, size, opacity, glowIntensity, rotation) {
      if (!ctx || opacity <= 0.001) return;
      ctx.save();
      if (glowIntensity > 0) {
        const glowR = size * (1.5 + glowIntensity * 2.5);
        const grd = ctx.createRadialGradient(cx, cy, size * 0.5, cx, cy, glowR);
        grd.addColorStop(0, `rgba(${VIO_R},${VIO_G},${VIO_B},${opacity * glowIntensity * 0.5})`);
        grd.addColorStop(0.4, `rgba(${VIO_R},${VIO_G},${VIO_B},${opacity * glowIntensity * 0.15})`);
        grd.addColorStop(0.7, `rgba(${CYN_R},${CYN_G},${CYN_B},${opacity * glowIntensity * 0.06})`);
        grd.addColorStop(1, 'transparent');
        ctx.fillStyle = grd;
        ctx.globalAlpha = 1;
        ctx.beginPath();
        ctx.arc(cx, cy, glowR, 0, Math.PI * 2);
        ctx.fill();
      }
      ctx.globalAlpha = opacity * 0.18;
      const fillGrd = ctx.createRadialGradient(cx, cy, 0, cx, cy, size);
      fillGrd.addColorStop(0, `rgba(${VIO_R},${VIO_G},${VIO_B},0.9)`);
      fillGrd.addColorStop(0.6, `rgba(${VIO_R},${VIO_G},${VIO_B},0.4)`);
      fillGrd.addColorStop(1, `rgba(${VIO_R},${VIO_G},${VIO_B},0.05)`);
      ctx.fillStyle = fillGrd;
      hexPath(cx, cy, size, rotation);
      ctx.fill();
      ctx.globalAlpha = opacity;
      ctx.strokeStyle = `rgba(${VIO_R},${VIO_G},${VIO_B},0.85)`;
      ctx.lineWidth = 2.5;
      ctx.shadowBlur = 20 * glowIntensity;
      ctx.shadowColor = `rgba(${VIO_R},${VIO_G},${VIO_B},0.8)`;
      hexPath(cx, cy, size, rotation);
      ctx.stroke();
      ctx.globalAlpha = opacity * 0.4;
      ctx.strokeStyle = `rgba(${CYN_R},${CYN_G},${CYN_B},0.6)`;
      ctx.lineWidth = 1;
      ctx.shadowBlur = 8;
      ctx.shadowColor = `rgba(${CYN_R},${CYN_G},${CYN_B},0.5)`;
      hexPath(cx, cy, size * 0.65, rotation + Math.PI / 6);
      ctx.stroke();
      ctx.globalAlpha = opacity * 0.9;
      ctx.fillStyle = '#ffffff';
      ctx.shadowBlur = 15;
      ctx.shadowColor = `rgba(${VIO_R},${VIO_G},${VIO_B},1)`;
      ctx.beginPath();
      ctx.arc(cx, cy, size * 0.06, 0, Math.PI * 2);
      ctx.fill();
      ctx.restore();
    }

    function drawShockwave(cx, cy, progress, opacity) {
      if (!ctx || progress <= 0 || opacity <= 0.001) return;
      ctx.save();
      const maxR = Math.max(W, H) * 1.3;
      const r = easeOut(progress) * maxR;
      const ringWidth = maxR * 0.06 * (1 - progress * 0.6);
      const innerR = Math.max(0, r - ringWidth);
      const grd = ctx.createRadialGradient(cx, cy, innerR, cx, cy, r + ringWidth * 0.5);
      grd.addColorStop(0, 'transparent');
      grd.addColorStop(0.4, `rgba(${VIO_R},${VIO_G},${VIO_B},${opacity * 0.55})`);
      grd.addColorStop(0.7, `rgba(${CYN_R},${CYN_G},${CYN_B},${opacity * 0.35})`);
      grd.addColorStop(1, 'transparent');
      ctx.fillStyle = grd;
      ctx.beginPath();
      ctx.arc(cx, cy, r + ringWidth * 0.5, 0, Math.PI * 2);
      ctx.arc(cx, cy, Math.max(0, innerR - ringWidth * 0.3), 0, Math.PI * 2, true);
      ctx.fill();
      if (r < maxR * 0.5) {
        ctx.globalAlpha = opacity * 0.4 * (1 - progress);
        ctx.strokeStyle = `rgba(${VIO_R},${VIO_G},${VIO_B},0.7)`;
        ctx.lineWidth = 2;
        hexPath(cx, cy, r, Math.PI / 6);
        ctx.stroke();
      }
      ctx.restore();
    }

    function drawNebulaReveal(cx, cy, progress) {
      if (!ctx || progress <= 0.05) return;
      ctx.save();
      const maxR = Math.max(W, H) * 1.3;
      const r = easeOut(progress) * maxR;
      ctx.beginPath();
      ctx.arc(cx, cy, r, 0, Math.PI * 2);
      ctx.clip();
      const clouds = [
        { x: 0.08, y: 0.08, r: 320, cr: VIO_R, cg: VIO_G, cb: VIO_B, o: 0.055 },
        { x: 0.82, y: 0.06, r: 280, cr: CYN_R, cg: CYN_G, cb: CYN_B, o: 0.040 },
        { x: 0.45, y: 0.20, r: 200, cr: 192, cg: 38, cb: 211, o: 0.030 },
        { x: 0.65, y: 0.35, r: 160, cr: VIO_R, cg: VIO_G, cb: VIO_B, o: 0.022 },
      ];
      clouds.forEach(c => {
        const grd = ctx.createRadialGradient(c.x * W, c.y * H, 0, c.x * W, c.y * H, c.r);
        grd.addColorStop(0, `rgba(${c.cr},${c.cg},${c.cb},${c.o})`);
        grd.addColorStop(1, 'transparent');
        ctx.fillStyle = grd;
        ctx.globalAlpha = progress;
        ctx.beginPath();
        ctx.arc(c.x * W, c.y * H, c.r, 0, Math.PI * 2);
        ctx.fill();
      });
      ctx.restore();
    }

    function drawDistantLight(cx, cy, size, opacity) {
      if (!ctx || opacity <= 0.001) return;
      ctx.save();
      const grd = ctx.createRadialGradient(cx, cy, 0, cx, cy, size);
      grd.addColorStop(0, `rgba(255,255,255,${opacity})`);
      grd.addColorStop(0.2, `rgba(${VIO_R},${VIO_G},${VIO_B},${opacity * 0.8})`);
      grd.addColorStop(0.6, `rgba(${VIO_R},${VIO_G},${VIO_B},${opacity * 0.2})`);
      grd.addColorStop(1, 'transparent');
      ctx.fillStyle = grd;
      ctx.beginPath();
      ctx.arc(cx, cy, size, 0, Math.PI * 2);
      ctx.fill();
      ctx.restore();
    }

    function render(ts) {
      if (done || !ctx) return;
      if (!startTime) startTime = ts;
      const t = ts - startTime;

      if (progressBar) {
        progressBar.style.width = Math.min(100, (t / TOTAL) * 100) + '%';
      }

      ctx.clearRect(0, 0, W, H);
      ctx.fillStyle = DEEP_BG;
      ctx.fillRect(0, 0, W, H);

      const cx = W / 2, cy = H / 2;

      const warpP = clamp(range(T.flyStart, T.arrivalStart, t), 0, 1);
      const warpFade = 1 - clamp(range(T.arrivalStart, T.arrivalPeak, t), 0, 1);
      drawStarField(warpP * 0.8, t);

      const approachP = clamp(range(T.flyStart, T.arrivalPeak, t), 0, 1);
      const distantSize = lerp(3, 80, easeIn(approachP));
      const distantOpacity = lerp(0.3, 0.9, easeIn(approachP)) * warpFade;
      drawDistantLight(cx, cy, distantSize, distantOpacity);

      const arrivalFlash = clamp(range(T.arrivalStart, T.arrivalPeak, t), 0, 1);
      const flashO = Math.sin(arrivalFlash * Math.PI) * 0.7;
      if (flashO > 0.001) {
        const grd = ctx.createRadialGradient(cx, cy, 0, cx, cy, W * 0.5);
        grd.addColorStop(0, `rgba(255,255,255,${flashO})`);
        grd.addColorStop(0.2, `rgba(${VIO_R},${VIO_G},${VIO_B},${flashO * 0.7})`);
        grd.addColorStop(1, 'transparent');
        ctx.save();
        ctx.fillStyle = grd;
        ctx.fillRect(0, 0, W, H);
        ctx.restore();
      }

      const hexP = clamp(range(T.hexReveal, T.hexGlow, t), 0, 1);
      const hexGlowP = clamp(range(T.hexGlow, T.genesisPulse, t), 0, 1);
      const pulsePeak = clamp(range(T.genesisPulse, T.genesisPulse + 300, t), 0, 1);
      const pulseFade = 1 - clamp(range(T.genesisPulse + 300, T.shockwaveEnd, t), 0, 1);
      const hexSize = Math.min(W, H) * 0.12 * (1 + Math.sin(pulsePeak * Math.PI) * 0.25);
      const hexOpacity = easeOut(hexP) * (0.5 + hexGlowP * 0.5) * pulseFade;
      const hexGlow = hexGlowP + pulsePeak * 1.5;
      const hexRot = Math.PI / 6 + t * 0.0003;
      if (hexOpacity > 0.001) drawHex(cx, cy, hexSize, hexOpacity, hexGlow, hexRot);

      const shockP = clamp(range(T.genesisPulse, T.shockwaveEnd, t), 0, 1);
      const shockO = (1 - easeIn(shockP)) * 0.8;
      drawShockwave(cx, cy, shockP, shockO);

      const nebulaP = clamp(range(T.genesisPulse + 200, T.shockwaveEnd + 500, t), 0, 1);
      drawNebulaReveal(cx, cy, nebulaP);

      if (t >= T.textShow && !textShown && sceneText) {
        textShown = true;
        sceneText.innerHTML = `
          <span class="intro-scene-label">Genesis Block · Block 0</span>
          <span class="intro-scene-title">Boing Network</span>
          <span class="intro-scene-sub">Authentic. Decentralized. Optimal. Quality-Assured.</span>
        `;
        sceneText.classList.add('show');
      }

      const liveBgP = clamp(range(T.outroStart, T.end, t), 0, 1);
      if (bgWrap) bgWrap.style.opacity = String(liveBgP);

      if (t >= T.end) {
        endIntro();
        return;
      }
      raf = requestAnimationFrame(render);
    }

    function endIntro() {
      if (done) return;
      done = true;
      if (raf) cancelAnimationFrame(raf);
      if (bgWrap) bgWrap.style.opacity = '1';
      overlay.classList.add('intro-exiting');
      document.documentElement.classList.remove('intro-active');
      document.documentElement.classList.add('intro-complete');
      setTimeout(() => {
        overlay.classList.add('intro-done');
      }, 1200);
    }

    function skipIntro() {
      if (done) return;
      done = true;
      if (raf) cancelAnimationFrame(raf);
      if (bgWrap) bgWrap.style.opacity = '1';
      overlay.classList.add('intro-exiting');
      document.documentElement.classList.remove('intro-active');
      document.documentElement.classList.add('intro-complete');
      setTimeout(() => {
        overlay.classList.add('intro-done');
      }, 700);
    }

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReducedMotion) {
      skipIntro();
      return;
    }

    document.documentElement.classList.add('intro-active');
    if (bgWrap) bgWrap.style.opacity = '0';
    resize();
    window.addEventListener('resize', resize);
    if (skipBtn) skipBtn.addEventListener('click', skipIntro);
    window.skipGenesisIntro = skipIntro;

    requestAnimationFrame(render);
  })();
</script>

<style>
  .intro-overlay {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    z-index: 100;
    background: #020408;
    overflow: hidden;
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transition: opacity 1.2s cubic-bezier(0.22, 1, 0.36, 1), visibility 1.2s step-end;
  }

  .intro-overlay.intro-done {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 1.2s cubic-bezier(0.22, 1, 0.36, 1), visibility 1.2s step-end 1.2s;
  }

  .intro-skip {
    position: absolute;
    top: 1.25rem;
    right: 1.5rem;
    z-index: 200;
    background: rgba(124, 58, 237, 0.08);
    border: 1px solid rgba(167, 139, 250, 0.2);
    color: rgba(167, 139, 250, 0.6);
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.35rem 0.875rem;
    border-radius: 999px;
    cursor: pointer;
    transition: all 0.2s;
    animation: genesis-skip-in 0.5s ease 0.3s both;
  }

  .intro-skip:hover {
    background: rgba(124, 58, 237, 0.16);
    color: var(--network-primary-light);
  }

  @keyframes genesis-skip-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .intro-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }

  .intro-scene-text {
    position: absolute;
    left: 50%;
    bottom: 16%;
    transform: translateX(-50%);
    text-align: center;
    pointer-events: none;
    opacity: 0;
    white-space: nowrap;
  }

  .intro-scene-text.show {
    animation: genesis-scene-in 0.7s ease forwards;
  }

  @keyframes genesis-scene-in {
    from {
      opacity: 0;
      transform: translateX(-50%) translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }
  }

  .intro-scene-label {
    display: block;
    font-family: var(--font-display, 'Orbitron', sans-serif);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(167, 139, 250, 0.5);
    margin-bottom: 0.5rem;
  }

  .intro-scene-title {
    display: block;
    font-family: var(--font-display, 'Orbitron', sans-serif);
    font-size: clamp(1.6rem, 4vw, 3.2rem);
    font-weight: 900;
    background: linear-gradient(135deg, #ffffff, var(--network-primary-light), var(--network-cyan));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .intro-scene-sub {
    display: block;
    font-size: 0.88rem;
    color: rgba(167, 139, 250, 0.5);
    margin-top: 0.5rem;
    letter-spacing: 0.06em;
  }

  .intro-progress-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--network-primary), var(--network-cyan), rgba(124, 58, 237, 0.3));
    width: 0%;
    box-shadow: 0 0 8px rgba(124, 58, 237, 0.6);
    transition: width 16ms linear;
  }
</style>

---
/**
 * In-hub navigation for testnet portal. Renders consistent links so users can move
 * between Hub home, My Dashboard, Community/Leaderboard, and Resources/Quests without going back.
 * current: 'index' | 'dashboard' | 'community' | 'resources' | 'quests' | 'leaderboard'
 */
interface Props {
  hub: 'developer' | 'user' | 'operator';
  current: 'index' | 'dashboard' | 'community' | 'resources' | 'quests' | 'leaderboard';
}
const { hub, current } = Astro.props;

const developerLinks = [
  { slug: 'index', label: 'Hub', href: '/testnet/developers' },
  { slug: 'dashboard', label: 'My Dashboard', href: '/testnet/developers/dashboard' },
  { slug: 'community', label: 'Community', href: '/testnet/developers/community' },
  { slug: 'resources', label: 'Resources', href: '/testnet/developers/resources' },
];

const userLinks = [
  { slug: 'index', label: 'Hub', href: '/testnet/users' },
  { slug: 'dashboard', label: 'My Dashboard', href: '/testnet/users/dashboard' },
  { slug: 'community', label: 'Community', href: '/testnet/users/community' },
  { slug: 'quests', label: 'Quests', href: '/testnet/users/quests' },
];

const operatorLinks = [
  { slug: 'index', label: 'Hub', href: '/testnet/operators' },
  { slug: 'dashboard', label: 'My Dashboard', href: '/testnet/operators/dashboard' },
  { slug: 'leaderboard', label: 'Leaderboard', href: '/testnet/operators/leaderboard' },
  { slug: 'resources', label: 'Resources', href: '/testnet/operators/resources' },
];

const links = hub === 'developer' ? developerLinks : hub === 'user' ? userLinks : operatorLinks;
---
<nav class="hub-nav" aria-label="Hub navigation">
  <ul class="hub-nav-list">
    {links.map((link) => (
      <li class="hub-nav-item">
        <a
          href={link.href}
          class:list={['hub-nav-link', { 'hub-nav-link--current': link.slug === current }]}
          aria-current={link.slug === current ? 'page' : undefined}
        >
          {link.label}
        </a>
      </li>
    ))}
  </ul>
</nav>

<style>
  .hub-nav {
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-color);
  }
  .hub-nav-list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 1rem;
    list-style: none;
    padding: 0;
    margin: 0;
    font-size: 0.9rem;
  }
  .hub-nav-link {
    color: var(--text-secondary);
    text-decoration: none;
    padding: 0.35rem 0.5rem;
    border-radius: 6px;
    transition: color 0.2s ease, background-color 0.2s ease;
  }
  .hub-nav-link:hover {
    color: var(--accent-teal);
  }
  .hub-nav-link--current {
    color: var(--accent-teal);
    font-weight: 600;
    background: rgba(34, 211, 238, 0.12);
  }
  .hub-nav-link:focus-visible {
    outline: 2px solid var(--accent-teal);
    outline-offset: 2px;
  }
</style>

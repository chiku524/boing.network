---
/**
 * Cinematic 3D initial animation for the homepage.
 * Narrative: dark → parallax depth → mascot reveal → ambient life. No orbits.
 * Aquatic–space theme; Boing mascot as hero. Respects prefers-reduced-motion.
 */
interface Props {
  autoDismissMs?: number;
}

const { autoDismissMs = 5200 } = Astro.props;
---

<div class="intro-overlay" id="intro-overlay" aria-hidden="true" data-auto-dismiss={autoDismissMs}>
  <div class="intro-backdrop"></div>
  <div class="intro-vignette" aria-hidden="true"></div>

  <!-- Parallax depth layers (stronger drift for more motion) -->
  <div class="intro-parallax" aria-hidden="true">
    <div class="parallax-layer layer-far" style="--drift-x: 4%; --drift-y: -2%; --duration: 26s;"></div>
    <div class="parallax-layer layer-mid-far" style="--drift-x: -3%; --drift-y: 2%; --duration: 20s;"></div>
    <div class="parallax-layer layer-mid" style="--drift-x: 2.5%; --drift-y: 1%; --duration: 16s;"></div>
    <div class="parallax-layer layer-near" style="--drift-x: -1.5%; --drift-y: -1%; --duration: 12s;"></div>
  </div>

  <!-- Atmospheric nebula + waterline (aquatic–space) -->
  <div class="intro-atmosphere" aria-hidden="true">
    <div class="intro-nebula intro-nebula-1"></div>
    <div class="intro-nebula intro-nebula-2"></div>
    <div class="intro-nebula intro-nebula-3"></div>
    <div class="intro-waterline"></div>
    <div class="intro-aurora"></div>
  </div>

  <!-- Sweeping light rays (cinematic) -->
  <div class="intro-light-rays" aria-hidden="true">
    <div class="light-ray ray-1"></div>
    <div class="light-ray ray-2"></div>
    <div class="light-ray ray-3"></div>
  </div>

  <!-- Mascot stage: camera drift + pulse ring + mascot -->
  <div class="intro-scene" id="intro-scene">
    <div class="intro-scene-camera" aria-hidden="true">
    <div class="intro-mascot-stage">
      <div class="intro-pulse-ring" aria-hidden="true"></div>
      <div class="intro-pulse-ring intro-pulse-ring-2" aria-hidden="true"></div>
      <div class="intro-mascot-wrap">
        <div class="intro-mascot-3d">
          <img src="/assets/mascot-excited.png" alt="" class="intro-mascot-img" width="320" height="320" />
        </div>
      </div>
    </div>
    </div>
  </div>

  <!-- Ambient: rising bubbles (aquatic) -->
  <div class="intro-bubbles" aria-hidden="true">
    <span class="rise-bubble b1"></span>
    <span class="rise-bubble b2"></span>
    <span class="rise-bubble b3"></span>
    <span class="rise-bubble b4"></span>
    <span class="rise-bubble b5"></span>
    <span class="rise-bubble b6"></span>
    <span class="rise-bubble b7"></span>
  </div>

  <!-- Floating particles (organic paths, 3D feel) -->
  <div class="intro-particles" aria-hidden="true">
    <span class="particle p1"></span>
    <span class="particle p2"></span>
    <span class="particle p3"></span>
    <span class="particle p4"></span>
    <span class="particle p5"></span>
    <span class="particle p6"></span>
  </div>

  <!-- Shooting star (one pass) -->
  <div class="intro-shooting-star" aria-hidden="true">
    <span class="shooting-star-line"></span>
  </div>

  <!-- Optional brand whisper -->
  <p class="intro-brand" aria-hidden="true">Boing Network</p>
  <p class="intro-hint">Scroll or tap to continue</p>
</div>

<script>
  (function () {
    const overlay = document.getElementById('intro-overlay');
    if (!overlay) return;

    document.documentElement.classList.add('intro-active');

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const autoDismissMs = parseInt(overlay.dataset.autoDismiss || '5200', 10);
    const OUTRO_HERO_REVEAL_MS = 500;   /* start hero reveal (intro-complete) so it overlaps with exit */
    const OUTRO_SCENE_MS = 1300;        /* then fade out overlay (intro-done) */

    function dismiss() {
      window.removeEventListener('click', dismiss);
      window.removeEventListener('scroll', dismiss, { passive: true });
      window.removeEventListener('keydown', onKey);

      overlay.classList.add('intro-exiting');
      overlay.setAttribute('aria-hidden', 'true');

      /* Start hero reveal mid-exit for cinematic cross-dissolve */
      setTimeout(function () {
        document.documentElement.classList.remove('intro-active');
        document.documentElement.classList.add('intro-complete');
      }, prefersReducedMotion ? 200 : OUTRO_HERO_REVEAL_MS);

      /* Then fade out overlay after mascot has moved toward hero */
      setTimeout(function () {
        overlay.classList.add('intro-done');
      }, prefersReducedMotion ? 500 : OUTRO_SCENE_MS);
    }

    function onKey(e) {
      if (e.key === 'Enter' || e.key === ' ' || e.key === 'Escape') {
        e.preventDefault();
        dismiss();
      }
    }

    window.addEventListener('click', dismiss, { once: true });
    window.addEventListener('scroll', dismiss, { passive: true, once: true });
    window.addEventListener('keydown', onKey, { once: true });

    if (!prefersReducedMotion && autoDismissMs > 0) {
      setTimeout(dismiss, autoDismissMs);
    }
  })();
</script>

<style>
  .intro-overlay {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    z-index: 25;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: auto;
    opacity: 1;
    visibility: visible;
    transition: opacity 1.25s cubic-bezier(0.22, 1, 0.36, 1), visibility 1.25s step-end;
  }

  .intro-overlay.intro-done {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 1.25s cubic-bezier(0.22, 1, 0.36, 1), visibility 1.25s step-end 1.25s;
  }

  .intro-backdrop {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 100% 100% at 50% 45%, #020408 0%, #050810 35%, #0a0f1a 70%, #0c1428 100%);
    z-index: 0;
    opacity: 0;
    animation: intro-backdrop-in 1.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes intro-backdrop-in {
    to { opacity: 1; }
  }

  .intro-exiting .intro-backdrop {
    animation: none;
    transition: opacity 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    opacity: 0.3;
  }

  .intro-vignette {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: radial-gradient(ellipse 75% 75% at 50% 50%, transparent 35%, rgba(0,0,0,0.5) 100%);
    opacity: 0;
    animation: vignette-in 2s cubic-bezier(0.22, 1, 0.36, 1) 0.4s forwards;
  }

  @keyframes vignette-in {
    to { opacity: 1; }
  }

  .intro-exiting .intro-vignette {
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  /* Parallax depth layers */
  .intro-parallax {
    position: absolute;
    inset: -10%;
    z-index: 0.5;
    pointer-events: none;
    overflow: hidden;
  }

  .parallax-layer {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    filter: blur(60px);
    opacity: 0;
    animation: parallax-fade-in 1.8s cubic-bezier(0.22, 1, 0.36, 1) forwards, parallax-drift var(--duration, 20s) ease-in-out infinite;
  }

  .parallax-layer.layer-far {
    width: 100%;
    height: 100%;
    max-width: 90vmax;
    max-height: 90vmax;
    margin: auto;
    background: radial-gradient(circle, rgba(124, 58, 237, 0.2) 0%, transparent 55%);
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    animation-delay: 0.2s, 0.5s;
  }

  .parallax-layer.layer-mid-far {
    width: 85%;
    height: 85%;
    max-width: 75vmax;
    max-height: 75vmax;
    margin: auto;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle, rgba(6, 182, 212, 0.15) 0%, transparent 60%);
    animation-delay: 0.4s, 0.8s;
  }

  .parallax-layer.layer-mid {
    width: 70%;
    height: 70%;
    margin: auto;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle, rgba(192, 38, 211, 0.12) 0%, transparent 65%);
    animation-delay: 0.6s, 1s;
  }

  .parallax-layer.layer-near {
    width: 55%;
    height: 55%;
    margin: auto;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle, rgba(124, 58, 237, 0.1) 0%, transparent 70%);
    animation-delay: 0.8s, 1.2s;
  }

  @keyframes parallax-fade-in {
    to { opacity: 1; }
  }

  @keyframes parallax-drift {
    0%, 100% { transform: translate(-50%, -50%) translate(0, 0); }
    25% { transform: translate(-50%, -50%) translate(var(--drift-x), var(--drift-y)); }
    50% { transform: translate(-50%, -50%) translate(calc(var(--drift-x) * -0.6), calc(var(--drift-y) * -0.6)); }
    75% { transform: translate(-50%, -50%) translate(calc(var(--drift-x) * 0.8), calc(var(--drift-y) * 0.8)); }
  }

  .intro-exiting .parallax-layer {
    opacity: 0;
    transition: opacity 0.6s ease;
  }

  /* Atmosphere: nebula + waterline + aurora */
  .intro-atmosphere {
    position: absolute;
    inset: 0;
    z-index: 0.6;
    pointer-events: none;
  }

  .intro-nebula {
    position: absolute;
    border-radius: 50%;
    filter: blur(70px);
    opacity: 0;
    animation: nebula-in 2s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  .intro-nebula-1 {
    width: min(80vw, 600px);
    height: min(80vw, 600px);
    background: radial-gradient(circle, var(--network-primary) 0%, transparent 65%);
    top: -10%; left: -15%;
    animation-delay: 0.5s;
  }

  .intro-nebula-2 {
    width: min(60vw, 450px);
    height: min(60vw, 450px);
    background: radial-gradient(circle, var(--network-cyan) 0%, transparent 65%);
    bottom: -15%; right: -10%;
    animation-delay: 0.8s;
  }

  .intro-nebula-3 {
    width: min(45vw, 320px);
    height: min(45vw, 320px);
    background: radial-gradient(circle, var(--network-nebula) 0%, transparent 70%);
    top: 35%; left: 55%;
    animation-delay: 1s;
  }

  @keyframes nebula-in {
    to { opacity: 0.22; }
  }

  .intro-waterline {
    position: absolute;
    left: 0;
    right: 0;
    top: 40%;
    height: 3px;
    background: linear-gradient(90deg, transparent 0%, rgba(6, 182, 212, 0.2) 30%, rgba(124, 58, 237, 0.25) 50%, rgba(6, 182, 212, 0.2) 70%, transparent 100%);
    opacity: 0;
    animation: waterline-in 1.5s cubic-bezier(0.22, 1, 0.36, 1) 1.2s forwards;
  }

  @keyframes waterline-in {
    to { opacity: 0.7; }
  }

  .intro-aurora {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 50%;
    background: linear-gradient(180deg, transparent 0%, rgba(6, 182, 212, 0.05) 30%, rgba(124, 58, 237, 0.07) 100%);
    opacity: 0;
    animation: nebula-in 2s cubic-bezier(0.22, 1, 0.36, 1) 1.4s forwards;
  }

  .intro-exiting .intro-nebula,
  .intro-exiting .intro-waterline,
  .intro-exiting .intro-aurora {
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  /* Light rays (sweeping, cinematic) */
  .intro-light-rays {
    position: absolute;
    inset: 0;
    z-index: 0.8;
    pointer-events: none;
    overflow: hidden;
  }

  .light-ray {
    position: absolute;
    width: 2px;
    height: 150%;
    top: -25%;
    left: 50%;
    margin-left: -1px;
    background: linear-gradient(180deg, transparent 0%, rgba(124, 58, 237, 0.08) 25%, rgba(6, 182, 212, 0.1) 50%, transparent 100%);
    transform-origin: center center;
    opacity: 0;
    animation: ray-sweep 24s linear infinite;
  }

  .light-ray.ray-1 { --r: 0deg; animation-delay: 0s; }
  .light-ray.ray-2 { --r: 120deg; animation-delay: -8s; }
  .light-ray.ray-3 { --r: 240deg; animation-delay: -16s; }

  @keyframes ray-sweep {
    0% { opacity: 0; transform: rotate(var(--r, 0deg)); }
    3% { opacity: 0.55; }
    7% { opacity: 0.2; }
    10% { opacity: 0; }
    100% { opacity: 0; transform: rotate(calc(var(--r, 0deg) + 360deg)); }
  }

  .intro-exiting .light-ray {
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  /* Scene: camera drift + mascot + pulse ring */
  .intro-scene {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    perspective: 1200px;
    transform-style: preserve-3d;
    opacity: 1;
    transform: scale(1) translateZ(0);
    transition: opacity 1.25s cubic-bezier(0.22, 1, 0.36, 1), transform 1.25s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .intro-exiting .intro-scene {
    opacity: 0;
    transform: scale(0.98) translateZ(-60px);
  }

  /* Slow camera-style drift (continuous motion within the frame) */
  .intro-scene-camera {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    animation: camera-drift 22s ease-in-out infinite;
  }

  @keyframes camera-drift {
    0%, 100% { transform: translate(0, 0); }
    25% { transform: translate(1.2%, 0.8%); }
    50% { transform: translate(-0.8%, -0.6%); }
    75% { transform: translate(0.6%, -0.4%); }
  }

  .intro-exiting .intro-scene-camera {
    animation: none;
  }

  .intro-mascot-stage {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: clamp(220px, 48vw, 340px);
    height: clamp(220px, 48vw, 340px);
    transform-style: preserve-3d;
  }

  /* Expanding pulse rings (sonar / energy from mascot) */
  .intro-pulse-ring {
    position: absolute;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    border: 2px solid rgba(124, 58, 237, 0.35);
    opacity: 0;
    transform: scale(0.6);
    animation: pulse-ring-expand 3s cubic-bezier(0.22, 1, 0.36, 1) 1.5s infinite;
  }

  .intro-pulse-ring-2 {
    animation-delay: 1.5s;
    border-color: rgba(6, 182, 212, 0.25);
  }

  @keyframes pulse-ring-expand {
    0% { opacity: 0.8; transform: scale(0.6); border-color: rgba(124, 58, 237, 0.4); }
    100% { opacity: 0; transform: scale(1.5); border-color: rgba(6, 182, 212, 0.1); }
  }

  .intro-mascot-wrap {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    transform-style: preserve-3d;
    opacity: 0;
    animation: mascot-reveal 1.8s cubic-bezier(0.16, 1, 0.3, 1) 0.7s forwards;
    filter: drop-shadow(0 0 50px var(--network-primary-glow)) drop-shadow(0 0 80px var(--network-cyan-glow));
    transition: opacity 1s ease, transform 1.3s cubic-bezier(0.22, 1, 0.36, 1);
  }

  /* Cinematic handoff: mascot moves toward hero position as overlay fades */
  .intro-exiting .intro-mascot-wrap {
    opacity: 1;
    transform: translate(22vw, 5vh) scale(0.88);
  }

  @media (max-width: 899px) {
    .intro-exiting .intro-mascot-wrap {
      transform: translate(0, 14vh) scale(0.82);
    }
  }

  .intro-mascot-3d {
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
    transform: rotateX(-5deg) rotateY(3deg);
    animation: mascot-float 7s ease-in-out infinite, mascot-breathe 4s ease-in-out infinite;
  }

  .intro-mascot-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    animation: mascot-glow 4s ease-in-out infinite;
  }

  @keyframes mascot-reveal {
    0% { opacity: 0; transform: scale(0.7) translateZ(-100px); filter: drop-shadow(0 0 20px rgba(124, 58, 237, 0.3)) blur(4px); }
    70% { filter: drop-shadow(0 0 50px var(--network-primary-glow)) drop-shadow(0 0 80px var(--network-cyan-glow)) blur(0); }
    100% { opacity: 1; transform: scale(1) translateZ(0); }
  }

  @keyframes mascot-float {
    0%, 100% { transform: rotateX(-5deg) rotateY(3deg) translateY(0) scale(1); }
    50% { transform: rotateX(-6deg) rotateY(4deg) translateY(-12px) scale(1.02); }
  }

  @keyframes mascot-glow {
    0%, 100% { filter: drop-shadow(0 0 35px var(--network-primary-glow)); }
    50% { filter: drop-shadow(0 0 55px var(--network-cyan-glow)); }
  }

  /* Rising bubbles (aquatic, vertical drift) */
  .intro-bubbles {
    position: absolute;
    inset: 0;
    z-index: 0.9;
    pointer-events: none;
  }

  .rise-bubble {
    position: absolute;
    border-radius: 50%;
    background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.5), var(--network-cyan) 60%, transparent 100%);
    box-shadow: 0 0 10px var(--network-cyan-glow);
    opacity: 0;
    animation: rise linear infinite;
  }

  .rise-bubble.b1 { width: 8px; height: 8px;  left: 12%; bottom: -5%; animation-duration: 8s;  animation-delay: 0s; }
  .rise-bubble.b2 { width: 6px; height: 6px;  left: 28%; bottom: -8%; animation-duration: 10s; animation-delay: -2s; }
  .rise-bubble.b3 { width: 10px; height: 10px; left: 52%; bottom: -12%; animation-duration: 9s;  animation-delay: -4s; }
  .rise-bubble.b4 { width: 5px; height: 5px;  right: 22%; bottom: -6%; animation-duration: 11s; animation-delay: -1s; }
  .rise-bubble.b5 { width: 7px; height: 7px;  right: 35%; bottom: -10%; animation-duration: 9.5s; animation-delay: -3s; }
  .rise-bubble.b6 { width: 6px; height: 6px;  left: 68%; bottom: -7%; animation-duration: 10.5s; animation-delay: -5s; }
  .rise-bubble.b7 { width: 9px; height: 9px;  right: 12%; bottom: -9%; animation-duration: 8.5s;  animation-delay: -2.5s; }

  @keyframes rise {
    0% { opacity: 0; transform: translate(0, 0) scale(0.8); }
    10% { opacity: 0.6; }
    25% { transform: translate(6px, -27vh) scale(0.9); }
    50% { transform: translate(-4px, -55vh) scale(1); }
    75% { transform: translate(5px, -82vh) scale(1); }
    90% { opacity: 0.4; }
    100% { opacity: 0; transform: translate(-3px, -110vh) scale(1); }
  }

  .intro-exiting .rise-bubble {
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  /* Floating particles (organic paths) */
  .intro-particles {
    position: absolute;
    inset: 0;
    z-index: 0.85;
    pointer-events: none;
  }

  .particle {
    position: absolute;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255,255,255,0.9), var(--network-cyan));
    box-shadow: 0 0 8px var(--network-cyan-glow);
    opacity: 0;
    animation: particle-float 12s ease-in-out infinite;
  }

  .particle.p1 { left: 15%; top: 20%; animation-delay: 0s;   animation-duration: 14s; }
  .particle.p2 { left: 75%; top: 30%; animation-delay: -3s;  animation-duration: 16s; }
  .particle.p3 { left: 45%; top: 70%; animation-delay: -5s;  animation-duration: 13s; }
  .particle.p4 { left: 25%; top: 55%; animation-delay: -2s;  animation-duration: 15s; }
  .particle.p5 { left: 65%; top: 15%; animation-delay: -7s;  animation-duration: 17s; }
  .particle.p6 { left: 55%; top: 80%; animation-delay: -4s;  animation-duration: 12s; }

  @keyframes particle-float {
    0%, 100% { opacity: 0; transform: translate(0, 0); }
    8% { opacity: 0.7; }
    25% { opacity: 0.6; transform: translate(8vw, -12vh); }
    50% { opacity: 0.5; transform: translate(-5vw, -25vh); }
    75% { opacity: 0.4; transform: translate(6vw, -40vh); }
    92% { opacity: 0.2; }
    100% { opacity: 0; transform: translate(4vw, -55vh); }
  }

  .intro-exiting .particle {
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  /* Shooting star */
  .intro-shooting-star {
    position: absolute;
    top: -5%;
    left: -15%;
    width: 0;
    height: 0;
    z-index: 1;
    pointer-events: none;
    opacity: 0;
    animation: shooting-star-pass 14s ease-in 2.5s forwards;
  }

  .intro-shooting-star .shooting-star-line {
    position: absolute;
    width: 140px;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--network-cyan-light), var(--network-primary));
    border-radius: 2px;
    box-shadow: 0 0 14px var(--network-cyan-glow);
    transform-origin: left center;
    transform: rotate(-22deg);
  }

  @keyframes shooting-star-pass {
    0% { opacity: 0; transform: translate(0, 0); }
    6% { opacity: 0.95; }
    12% { opacity: 0; transform: translate(150vw, 45vh); }
    100% { opacity: 0; transform: translate(150vw, 45vh); }
  }

  .intro-exiting .intro-shooting-star {
    opacity: 0;
  }

  /* Brand whisper */
  .intro-brand {
    position: absolute;
    bottom: clamp(3rem, 12vh, 5rem);
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    margin: 0;
    font-family: var(--font-display, 'Orbitron', sans-serif);
    font-size: clamp(0.7rem, 1.8vw, 0.9rem);
    font-weight: 600;
    letter-spacing: 0.25em;
    color: rgba(248, 250, 252, 0.5);
    opacity: 0;
    animation: brand-in 1.2s cubic-bezier(0.22, 1, 0.36, 1) 2.8s forwards;
  }

  @keyframes brand-in {
    to { opacity: 0.6; }
  }

  .intro-exiting .intro-brand {
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .intro-hint {
    position: absolute;
    bottom: clamp(1.25rem, 4vh, 2.5rem);
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    margin: 0;
    font-size: clamp(0.7rem, 1.8vw, 0.85rem);
    color: var(--text-secondary);
    letter-spacing: 0.1em;
    opacity: 0;
    animation: hint-in 0.9s cubic-bezier(0.22, 1, 0.36, 1) 3.2s forwards;
    transition: opacity 0.5s ease;
  }

  .intro-exiting .intro-hint {

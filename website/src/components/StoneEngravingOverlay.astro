---
/**
 * Stone-like engraved graphic layer: texture, carved groove paths, neon accents.
 * Sits above the canvas background, below main content (z-index 0, after canvas in DOM).
 */
---

<div class="site-stone-engrave" aria-hidden="true">
  <div class="site-stone-engrave__texture"></div>
  <svg
    class="site-stone-engrave__svg"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 320 1200"
    preserveAspectRatio="xMidYMin meet"
    focusable="false"
  >
    <defs>
      <filter id="stone-engrave-neon" x="-80%" y="-80%" width="260%" height="260%">
        <feGaussianBlur in="SourceGraphic" stdDeviation="4" result="b" />
        <feMerge>
          <feMergeNode in="b" />
          <feMergeNode in="SourceGraphic" />
        </feMerge>
      </filter>
      <filter id="stone-engrave-soft-glow" x="-100%" y="-100%" width="300%" height="300%">
        <feGaussianBlur in="SourceGraphic" stdDeviation="10" result="g" />
        <feMerge>
          <feMergeNode in="g" />
          <feMergeNode in="g" />
          <feMergeNode in="SourceGraphic" />
        </feMerge>
      </filter>
      <linearGradient id="stone-engrave-edge" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="rgba(0,0,0,0.55)" />
        <stop offset="45%" stop-color="rgba(255,255,255,0.12)" />
        <stop offset="100%" stop-color="rgba(0,0,0,0.45)" />
      </linearGradient>
    </defs>

    <!-- Carved channels (read as recessed stone) -->
    <g class="site-stone-engrave__grooves" fill="none" stroke-linecap="round" stroke-linejoin="round">
      <!-- Outer dark rim -->
      <path
        class="site-stone-engrave__groove-shadow"
        d="M 168 0 L 168 72 C 168 108 124 124 98 152 C 72 180 210 196 188 236 C 166 276 118 292 142 332 C 166 372 228 388 204 432 C 180 476 96 492 124 540 C 152 588 248 604 220 656 C 192 708 88 724 118 780 C 148 836 262 852 232 912 C 202 972 76 988 108 1050 C 140 1112 188 1136 160 1200"
        stroke="rgba(0,0,0,0.5)"
        stroke-width="5"
      />
      <!-- Highlight bevel -->
      <path
        class="site-stone-engrave__groove-light"
        d="M 168 0 L 168 72 C 168 108 124 124 98 152 C 72 180 210 196 188 236 C 166 276 118 292 142 332 C 166 372 228 388 204 432 C 180 476 96 492 124 540 C 152 588 248 604 220 656 C 192 708 88 724 118 780 C 148 836 262 852 232 912 C 202 972 76 988 108 1050 C 140 1112 188 1136 160 1200"
        stroke="url(#stone-engrave-edge)"
        stroke-width="2.2"
        opacity="0.9"
      />
      <!-- Branch network (all connected to main spine) -->
      <path
        class="site-stone-engrave__groove-shadow"
        d="M 168 72 L 236 88 C 268 96 284 128 270 164 C 256 200 220 212 196 228"
        stroke="rgba(0,0,0,0.45)"
        stroke-width="4"
      />
      <path
        class="site-stone-engrave__groove-light"
        d="M 168 72 L 236 88 C 268 96 284 128 270 164 C 256 200 220 212 196 228"
        stroke="url(#stone-engrave-edge)"
        stroke-width="1.8"
        opacity="0.85"
      />
      <path
        class="site-stone-engrave__groove-shadow"
        d="M 98 152 L 44 168 C 12 178 -4 210 18 244 C 40 278 86 286 118 292"
        stroke="rgba(0,0,0,0.45)"
        stroke-width="4"
      />
      <path
        class="site-stone-engrave__groove-light"
        d="M 98 152 L 44 168 C 12 178 -4 210 18 244 C 40 278 86 286 118 292"
        stroke="url(#stone-engrave-edge)"
        stroke-width="1.8"
        opacity="0.85"
      />
      <path
        class="site-stone-engrave__groove-shadow"
        d="M 142 332 L 76 348 C 38 358 22 402 52 438 C 82 474 124 468 152 456"
        stroke="rgba(0,0,0,0.45)"
        stroke-width="4"
      />
      <path
        class="site-stone-engrave__groove-light"
        d="M 142 332 L 76 348 C 38 358 22 402 52 438 C 82 474 124 468 152 456"
        stroke="url(#stone-engrave-edge)"
        stroke-width="1.8"
        opacity="0.85"
      />
      <path
        class="site-stone-engrave__groove-shadow"
        d="M 124 540 L 288 556 C 312 560 328 596 308 628 C 288 660 248 668 220 656"
        stroke="rgba(0,0,0,0.45)"
        stroke-width="4"
      />
      <path
        class="site-stone-engrave__groove-light"
        d="M 124 540 L 288 556 C 312 560 328 596 308 628 C 288 660 248 668 220 656"
        stroke="url(#stone-engrave-edge)"
        stroke-width="1.8"
        opacity="0.85"
      />
      <path
        class="site-stone-engrave__groove-shadow"
        d="M 118 780 L 32 804 C 4 812 -8 848 14 882 C 36 916 78 920 108 918"
        stroke="rgba(0,0,0,0.45)"
        stroke-width="4"
      />
      <path
        class="site-stone-engrave__groove-light"
        d="M 118 780 L 32 804 C 4 812 -8 848 14 882 C 36 916 78 920 108 918"
        stroke="url(#stone-engrave-edge)"
        stroke-width="1.8"
        opacity="0.85"
      />
    </g>

    <!-- Neon accents along the network -->
    <g class="site-stone-engrave__neon" filter="url(#stone-engrave-neon)">
      <path
        d="M 168 0 L 168 72 C 168 108 124 124 98 152 C 72 180 210 196 188 236 C 166 276 118 292 142 332 C 166 372 228 388 204 432 C 180 476 96 492 124 540 C 152 588 248 604 220 656 C 192 708 88 724 118 780 C 148 836 262 852 232 912 C 202 972 76 988 108 1050 C 140 1112 188 1136 160 1200"
        fill="none"
        stroke="rgba(0, 217, 255, 0.35)"
        stroke-width="2"
        stroke-linecap="round"
        class="site-stone-engrave__neon-line"
      />
      <path
        d="M 168 72 L 236 88 C 268 96 284 128 270 164 C 256 200 220 212 196 228"
        fill="none"
        stroke="rgba(0, 153, 255, 0.28)"
        stroke-width="1.6"
        stroke-linecap="round"
        class="site-stone-engrave__neon-line site-stone-engrave__neon-line--delay"
      />
      <path
        d="M 98 152 L 44 168 C 12 178 -4 210 18 244 C 40 278 86 286 118 292"
        fill="none"
        stroke="rgba(139, 92, 246, 0.22)"
        stroke-width="1.6"
        stroke-linecap="round"
        class="site-stone-engrave__neon-line site-stone-engrave__neon-line--delay2"
      />
      <path
        d="M 124 540 L 288 556 C 312 560 328 596 308 628 C 288 660 248 668 220 656"
        fill="none"
        stroke="rgba(0, 217, 255, 0.25)"
        stroke-width="1.5"
        stroke-linecap="round"
        class="site-stone-engrave__neon-line site-stone-engrave__neon-line--delay3"
      />
    </g>

    <!-- Node glows (junctions) -->
    <g class="site-stone-engrave__nodes" filter="url(#stone-engrave-soft-glow)">
      <circle cx="168" cy="72" r="5" fill="rgba(0, 217, 255, 0.45)" class="site-stone-engrave__node" />
      <circle cx="98" cy="152" r="4.5" fill="rgba(0, 153, 255, 0.4)" class="site-stone-engrave__node site-stone-engrave__node--delay" />
      <circle cx="142" cy="332" r="4.5" fill="rgba(167, 139, 250, 0.35)" class="site-stone-engrave__node site-stone-engrave__node--delay2" />
      <circle cx="124" cy="540" r="5" fill="rgba(0, 217, 255, 0.4)" class="site-stone-engrave__node site-stone-engrave__node--delay3" />
      <circle cx="118" cy="780" r="4.5" fill="rgba(0, 153, 255, 0.38)" class="site-stone-engrave__node" />
      <circle cx="108" cy="1050" r="5" fill="rgba(0, 217, 255, 0.42)" class="site-stone-engrave__node site-stone-engrave__node--delay" />
    </g>
  </svg>
</div>

<style>
  .site-stone-engrave {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    /* Above canvas (0) and body pseudo-layers like .page-landing::before (0); main/footer use same layer but come later in DOM */
    z-index: 1;
    pointer-events: none;
    overflow: hidden;
  }

  .site-stone-engrave__texture {
    position: absolute;
    inset: 0;
    /* Chiseled stone read: cool slate, uneven light, fine grain */
    background-color: rgba(6, 18, 30, 0.42);
    background-image:
      url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.4'/%3E%3C/svg%3E"),
      radial-gradient(ellipse 130% 55% at 50% -15%, rgba(255, 255, 255, 0.06), transparent 52%),
      radial-gradient(ellipse 90% 50% at 92% 72%, rgba(0, 120, 140, 0.12), transparent 48%),
      radial-gradient(ellipse 70% 45% at 8% 45%, rgba(0, 40, 60, 0.2), transparent 50%),
      linear-gradient(
        168deg,
        rgba(12, 32, 48, 0.55) 0%,
        rgba(8, 22, 36, 0.62) 42%,
        rgba(6, 16, 28, 0.58) 100%
      );
    background-blend-mode: overlay, normal, normal, normal, normal;
    mix-blend-mode: multiply;
    opacity: 0.92;
  }

  .site-stone-engrave__svg {
    position: absolute;
    left: 50%;
    top: 0;
    width: min(52vw, 520px);
    height: 100%;
    min-height: 100%;
    transform: translateX(-50%);
    opacity: 0.88;
  }

  @media (min-width: 1200px) {
    .site-stone-engrave__svg {
      width: min(44vw, 580px);
    }
  }

  @media (max-width: 640px) {
    .site-stone-engrave__svg {
      width: 78vw;
      opacity: 0.75;
    }
    .site-stone-engrave__texture {
      opacity: 0.88;
    }
  }

  .site-stone-engrave__neon-line {
    animation: stone-engrave-neon-pulse 5.5s ease-in-out infinite;
  }
  .site-stone-engrave__neon-line--delay {
    animation-delay: 1.1s;
  }
  .site-stone-engrave__neon-line--delay2 {
    animation-delay: 2.2s;
  }
  .site-stone-engrave__neon-line--delay3 {
    animation-delay: 3.1s;
  }

  .site-stone-engrave__node {
    animation: stone-engrave-node-pulse 4.2s ease-in-out infinite;
  }
  .site-stone-engrave__node--delay {
    animation-delay: 0.9s;
  }
  .site-stone-engrave__node--delay2 {
    animation-delay: 1.8s;
  }
  .site-stone-engrave__node--delay3 {
    animation-delay: 2.7s;
  }

  @keyframes stone-engrave-neon-pulse {
    0%,
    100% {
      stroke-opacity: 0.22;
    }
    50% {
      stroke-opacity: 0.55;
    }
  }

  @keyframes stone-engrave-node-pulse {
    0%,
    100% {
      opacity: 0.45;
    }
    50% {
      opacity: 0.95;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .site-stone-engrave__neon-line,
    .site-stone-engrave__node {
      animation: none;
    }
    .site-stone-engrave__neon-line {
      stroke-opacity: 0.38;
    }
    .site-stone-engrave__node {
      opacity: 0.7;
    }
  }
</style>

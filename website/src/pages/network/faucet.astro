---
import Layout from '../../layouts/Layout.astro';
import Icon from '../../components/Icon.astro';
import CopyButton from '../../components/CopyButton.astro';
import { TESTNET_RPC_URL } from '../../config/testnet';
---

<Layout
  title="Testnet Faucet"
  description="Request testnet BOING for the Boing Network testnet."
>
  <article class="page-wrap-full">
    <header class="page-hero-full">
      <div class="page-wrap-inner">
        <span class="stage-badge-global">Testnet</span>
        <h1 class="page-title"><Icon name="faucet" size={32} class="title-icon" /> Testnet Faucet</h1>
        <p class="lead">
          Get testnet BOING to pay for gas and stake. Enter your account ID (32-byte hex) and the faucet will send <strong>1,000</strong> testnet BOING to your account. Rate limit: 1 request per 60 seconds per account.
        </p>
      </div>
    </header>
    <div class="page-wrap-inner faucet-content">
      <section class="faucet-form">
      <div class="copy-wrapper input-group">
        <label for="rpc-url">Testnet RPC URL</label>
        <div class="input-with-copy">
          <input
            id="rpc-url"
            type="text"
            placeholder="https://testnet-rpc.boing.network or http://127.0.0.1:8545"
            value={TESTNET_RPC_URL}
          />
          <CopyButton label="Copy" copiedLabel="Copied!" />
        </div>
      </div>
      <label for="account-id">Your account ID (32-byte hex, with or without 0x)</label>
      <input
        id="account-id"
        type="text"
        placeholder="0x..."
        maxlength="66"
      />
      <button id="request-btn" type="button" aria-busy="false">
        <span class="faucet-btn-inner">
          <span class="faucet-btn-label">Request 1,000 testnet BOING</span>
          <span class="boing-loader boing-loader--sm faucet-inline-loader" hidden aria-hidden="true">
            <span class="boing-loader__dot"></span><span class="boing-loader__dot"></span><span class="boing-loader__dot"></span>
          </span>
        </span>
      </button>
      <p id="message" class="message" aria-live="polite" data-state=""></p>
    </section>

    <section class="section">
      <h2>How it works</h2>
      <ul>
        <li>The faucet is an RPC method (<code>boing_faucetRequest</code>) on nodes started with <code>--faucet-enable</code>.</li>
        <li>Use the RPC URL of a testnet node that has the faucet enabled. For local testing, run <code>boing-node --validator --faucet-enable --rpc-port 8545</code> and use <code>http://127.0.0.1:8545</code>.</li>
        <li>Your account ID is the 32-byte hex representation of your public key (e.g. from your wallet).</li>
      </ul>
    </section>

    <section class="section">
      <h2>Docs</h2>
      <p><a href="/network/testnet">Join Testnet</a> · <a href="/pdfs/TESTNET.pdf" target="_blank" rel="noopener">TESTNET (PDF)</a></p>
    </section>
    </div>
  </article>
</Layout>

<script>
  (function () {
    const rpcInput = document.getElementById('rpc-url') as HTMLInputElement;
    const accountInput = document.getElementById('account-id') as HTMLInputElement;
    const btn = document.getElementById('request-btn') as HTMLButtonElement;
    const messageEl = document.getElementById('message') as HTMLParagraphElement;
    const faucetLabel = btn?.querySelector('.faucet-btn-label');
    const faucetLoader = btn?.querySelector('.faucet-inline-loader') as HTMLElement | null;

    // Prefill account ID from ?address= (e.g. from boing.observer or wallet deep link)
    const params = new URLSearchParams(window.location.search);
    const addressParam = params.get('address');
    if (accountInput && addressParam && /^(0x)?[0-9a-fA-F]{64}$/.test(addressParam.trim())) {
      accountInput.value = addressParam.trim().toLowerCase().startsWith('0x') ? addressParam.trim() : '0x' + addressParam.trim();
    }

    function setMessage(text: string, isError = false) {
      messageEl.textContent = text;
      messageEl.setAttribute('data-state', isError ? 'error' : 'success');
      messageEl.style.color = '';
    }

    btn?.addEventListener('click', async () => {
      const rpcUrl = (rpcInput?.value || '').trim().replace(/\/$/, '');
      let accountHex = (accountInput?.value || '').trim();
      if (!rpcUrl) {
        setMessage('Please enter the Testnet RPC URL.', true);
        return;
      }
      if (!accountHex) {
        setMessage('Please enter your account ID (32-byte hex).', true);
        return;
      }
      if (!accountHex.startsWith('0x')) accountHex = '0x' + accountHex;
      if (accountHex.length !== 66) {
        setMessage('Account ID must be 32 bytes (64 hex chars + 0x).', true);
        return;
      }

      btn.disabled = true;
      btn.setAttribute('aria-busy', 'true');
      if (faucetLabel) (faucetLabel as HTMLElement).textContent = 'Requesting…';
      if (faucetLoader) faucetLoader.hidden = false;
      setMessage('Requesting…');

      try {
        const res = await fetch(rpcUrl, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            jsonrpc: '2.0',
            id: 1,
            method: 'boing_faucetRequest',
            params: [accountHex],
          }),
        });
        const data = await res.json();

        if (data.error) {
          setMessage(data.error.message || 'Request failed.', true);
          return;
        }
        if (data.result?.ok) {
          setMessage(`Success! ${data.result.amount} testnet BOING sent. ${data.result.message || ''}`);
        } else {
          setMessage(data.result?.message || 'Request may have succeeded; check your wallet.', false);
        }
      } catch (e) {
        setMessage('Network error: ' + (e instanceof Error ? e.message : String(e)), true);
      } finally {
        btn.disabled = false;
        btn.setAttribute('aria-busy', 'false');
        if (faucetLabel) (faucetLabel as HTMLElement).textContent = 'Request 1,000 testnet BOING';
        if (faucetLoader) {
          faucetLoader.hidden = true;
          faucetLoader.setAttribute('aria-hidden', 'true');
        }
      }
    });
  })();
</script>

<style>
  .faucet-content { padding-bottom: 3rem; max-width: 640px; }
  .page-title { display: flex; align-items: center; gap: 0.5rem; color: var(--text-primary); }
  .title-icon { color: var(--accent-teal); flex-shrink: 0; }
  .faucet-page h1 { color: var(--text-primary); }
  .lead { color: var(--text-secondary); font-size: 1.05rem; margin-bottom: 1.5rem; }
  .faucet-form label { display: block; margin-top: 1rem; color: var(--text-secondary); font-size: 0.9rem; }
  .faucet-form .input-with-copy {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.25rem;
    flex-wrap: wrap;
  }
  .faucet-form .input-with-copy input { flex: 1; min-width: 200px; }
  @media (max-width: 360px) {
    .faucet-form .input-with-copy { flex-direction: column; align-items: stretch; }
    .faucet-form .input-with-copy input { min-width: 0; }
  }
  .faucet-form input {
    width: 100%;
    max-width: 100%;
    padding: 12px 16px;
    margin-top: 0.25rem;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    border: 1px solid var(--border-color);
    border-radius: 8px;
    background: var(--bg-tertiary);
    color: var(--text-primary);
  }
  .faucet-form input:focus {
    outline: none;
    border-color: var(--accent-teal);
    box-shadow: 0 0 8px var(--glow-cyan);
  }
  .faucet-form input::placeholder {
    color: var(--text-tertiary);
  }
  .faucet-form button {
    margin-top: 1.25rem;
    padding: 0.6rem 1.2rem;
    font-size: 1rem;
    font-weight: 600;
    border: none;
    border-radius: 6px;
    background: linear-gradient(135deg, var(--accent-teal), var(--accent-cyan));
    color: var(--bg-primary);
    cursor: pointer;
  }
  .faucet-form button:hover:not(:disabled) { opacity: 0.9; }
  .faucet-form button:disabled { opacity: 0.6; cursor: not-allowed; }
  .faucet-form button[aria-busy="true"] {
    position: relative;
  }
  .faucet-btn-inner {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }
  .faucet-inline-loader[hidden] {
    display: none !important;
  }
  .faucet-inline-loader:not([hidden]) {
    display: inline-flex !important;
  }
  .message { margin-top: 1rem; min-height: 1.5em; font-size: 0.95rem; }
  .message[data-state="success"] { color: var(--accent-teal); font-weight: 500; }
  .message[data-state="error"] { color: var(--error-color, #f87171); }
  .section { margin-top: 2rem; }
  .section h2 { font-size: 1.2rem; color: var(--text-primary); }
  .section p, .section li { color: var(--text-secondary); }
  .section code { background: rgba(255,255,255,0.08); padding: 0.15rem 0.4rem; border-radius: 4px; font-size: 0.9em; }
</style>

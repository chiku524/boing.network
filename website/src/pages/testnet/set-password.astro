---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Set portal password — Testnet Portal"
  description="Set or update your portal password so you can sign in with your Boing wallet. Prove control by signing a message."
>
  <article class="portal-page sign-in-page page-wrap-full">
    <header class="page-hero-full page-hero-signin">
      <div class="page-wrap-inner sign-in-hero-inner">
        <span class="stage-badge-global">Testnet</span>
        <p class="back-link" style="margin-bottom: 1rem;"><a href="/testnet/sign-in">← Sign in</a></p>
        <h1 class="sign-in-hero-title">Set portal password</h1>
        <p class="lead">
          Sign a message with your wallet to prove you control this account, then set a password. You will use this password when signing in with your wallet.
        </p>
      </div>
    </header>
    <div class="page-wrap-inner sign-in-content">
      <section class="auth-option connect-wallet-section">
        <form id="set-password-form" class="auth-form">
          <label for="account-id">Account ID (from wallet or paste 0x... 64 hex)</label>
          <input id="account-id" name="account_id_hex" type="text" placeholder="0x..." maxlength="66" required autocomplete="off" />
          <p class="form-hint"><button type="button" id="connect-wallet-btn" class="link-btn">Connect wallet</button><span id="wallet-actions"></span> to fill from your wallet</p>

          <label for="new-password">New portal password (min 8 characters) *</label>
          <input id="new-password" name="new_password" type="password" placeholder="••••••••" minlength="8" required autocomplete="new-password" />

          <label for="confirm-password">Confirm password *</label>
          <input id="confirm-password" name="confirm_password" type="password" placeholder="••••••••" minlength="8" required autocomplete="new-password" />

          <button type="submit" id="submit-btn">Set password</button>
          <p id="form-message" class="form-message" aria-live="polite"></p>
        </form>
      </section>
      <section class="section">
        <p><a href="/testnet/sign-in">← Back to Sign in</a></p>
      </section>
    </div>
  </article>
</Layout>

<script is:inline src="/portal-session.js"></script>
<script is:inline src="/portal-wallet.js"></script>
<script>
  (function () {
    var form = document.getElementById('set-password-form');
    var connectBtn = document.getElementById('connect-wallet-btn');
    var accountInput = document.getElementById('account-id');
    var submitBtn = document.getElementById('submit-btn');
    var messageEl = document.getElementById('form-message');

    function setMessage(text, isError, isSuccess) {
      if (messageEl) {
        messageEl.textContent = text;
        messageEl.classList.remove('form-message--error', 'form-message--success');
        if (isSuccess) messageEl.classList.add('form-message--success');
        else if (isError) messageEl.classList.add('form-message--error');
      }
    }

    var urlParams = new URLSearchParams(window.location.search);
    var prefill = urlParams.get('account_id_hex');
    if (prefill && accountInput) {
      accountInput.value = prefill.trim().toLowerCase().startsWith('0x') ? prefill.trim() : '0x' + prefill.trim();
    }

    function getProvider() {
      return typeof window !== 'undefined' ? ((window.BoingPortalWallet && window.BoingPortalWallet.getProvider && window.BoingPortalWallet.getProvider()) || window.boing || window.ethereum || null) : null;
    }
    function providerMethod(primary, fallback) {
      return function (provider, params) {
        return provider.request({ method: primary, params: params || [] }).catch(function (err) {
          var msg = (err && err.message || '').toLowerCase();
          if (!fallback || primary === fallback || (msg.indexOf('not found') === -1 && msg.indexOf('unsupported') === -1)) throw err;
          return provider.request({ method: fallback, params: params || [] });
        });
      };
    }
    var requestAccounts = providerMethod('boing_requestAccounts', 'eth_requestAccounts');
    var signMessage = providerMethod('boing_signMessage', 'personal_sign');
    var getChainId = providerMethod('boing_chainId', 'eth_chainId');
    var switchChain = providerMethod('boing_switchChain', 'wallet_switchEthereumChain');
    function buildConnectMessage() {
      var origin = window.location.origin || '';
      var timestamp = new Date().toISOString();
      return 'Connect to Boing Portal\nOrigin: ' + origin + '\nTimestamp: ' + timestamp;
    }

    async function ensureTestnetChain(provider) {
      try {
        var chainId = await getChainId(provider, []);
        if (chainId && String(chainId).toLowerCase() === '0x1b01') return true;
        setMessage('Switching wallet to Boing Testnet…', false);
        await switchChain(provider, [{ chainId: '0x1b01' }]);
        return true;
      } catch (err) {
        setMessage('Please switch your wallet to Boing Testnet and try again.', true);
        return false;
      }
    }

    if (connectBtn) {
      connectBtn.addEventListener('click', async function () {
        var provider = getProvider();
        if (!provider) {
          setMessage('No Boing wallet found. Install Boing Express (boing.express) or a Boing-compatible wallet.', true);
          return;
        }
        connectBtn.disabled = true;
        setMessage('Connecting…');
        try {
          var ok = await ensureTestnetChain(provider);
          if (!ok) { connectBtn.disabled = false; return; }
          var accounts = await requestAccounts(provider, []);
          var address = Array.isArray(accounts) && accounts[0] ? accounts[0] : null;
          if (!address) {
            setMessage('No account selected.', true);
            connectBtn.disabled = false;
            return;
          }
          setMessage('Approve the connection in your wallet…');
          var connectMsg = buildConnectMessage();
          var connectSignature = await signMessage(provider, [connectMsg, address]).catch(function (err) {
            if (err && (String(err.message || '').toLowerCase().indexOf('reject') !== -1 || String(err.message || '').toLowerCase().indexOf('denied') !== -1 || String(err.message || '').toLowerCase().indexOf('cancel') !== -1)) return null;
            throw err;
          });
          if (!connectSignature || typeof connectSignature !== 'string') {
            setMessage('Connection was not approved in your wallet. Please approve the request in your wallet to connect.', true);
            connectBtn.disabled = false;
            return;
          }
          if (accountInput) {
            accountInput.value = address;
            setMessage('Account filled. Set your password below.', false);
            var actions = document.getElementById('wallet-actions');
            if (actions) { actions.innerHTML = ' · <button type="button" class="link-btn" id="clear-account-btn">Clear account</button>'; }
            var clearBtn = document.getElementById('clear-account-btn');
            if (clearBtn) clearBtn.onclick = function () { accountInput.value = ''; setMessage(''); if (actions) actions.innerHTML = ''; };
          }
        } catch (err) {
          var msg = (window.BoingPortalWallet && window.BoingPortalWallet.normalizeWalletError && window.BoingPortalWallet.normalizeWalletError(err.message)) || err.message || 'Connection failed.';
          setMessage(msg, true);
        }
        connectBtn.disabled = false;
      });
    }

    if (form) {
      form.addEventListener('submit', async function (e) {
        e.preventDefault();
        var accountHex = (accountInput && accountInput.value || '').trim();
        if (!accountHex.startsWith('0x')) accountHex = '0x' + accountHex;
        if (accountHex.length !== 66) {
          setMessage('Account ID must be 32 bytes (64 hex + 0x).', true);
          return;
        }
        var newPassword = document.getElementById('new-password').value;
        var confirmPassword = document.getElementById('confirm-password').value;
        if (newPassword.length < 8) {
          setMessage('Password must be at least 8 characters.', true);
          return;
        }
        if (newPassword !== confirmPassword) {
          setMessage('Passwords do not match.', true);
          return;
        }

        var provider = getProvider();
        if (!provider) {
          setMessage('Connect your wallet first to sign the set-password message.', true);
          return;
        }
        submitBtn.disabled = true;
        setMessage('Requesting nonce…');
        try {
          var origin = window.location.origin || '';
          var nonceRes = await fetch('/api/portal/auth/nonce?origin=' + encodeURIComponent(origin));
          var nonceData = await nonceRes.json().catch(function () { return {}; });
          if (!nonceRes.ok || !nonceData.ok || !nonceData.nonce) {
            setMessage(nonceData.message || 'Could not get nonce.', true);
            submitBtn.disabled = false;
            return;
          }
          var timestamp = new Date().toISOString();
          var message = 'Set portal password for Boing Portal\nOrigin: ' + nonceData.origin + '\nTimestamp: ' + timestamp + '\nNonce: ' + nonceData.nonce;
          setMessage('Please sign the message in your wallet…');
          var signature = await signMessage(provider, [message, accountHex]);
          if (!signature || typeof signature !== 'string') {
            setMessage('Signing was cancelled or failed.', true);
            submitBtn.disabled = false;
            return;
          }
          setMessage('Setting password…');
          var res = await fetch('/api/portal/auth/set-password', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              account_id_hex: accountHex,
              message: message,
              signature: signature,
              new_password: newPassword
            })
          });
          var data = await res.json().catch(function () { return {}; });
          if (!res.ok) {
            setMessage(data.message || 'Failed to set password.', true);
            submitBtn.disabled = false;
            return;
          }
          setMessage('Password set. Redirecting to sign in…', false, true);
          setTimeout(function () {
            window.location.href = '/testnet/sign-in';
          }, 800);
        } catch (err) {
          setMessage(err.message || 'Request failed. Try again.', true);
          submitBtn.disabled = false;
        }
      });
    }
  })();
</script>

<style>
  .portal-page { padding: 0; margin: 0; width: 100%; }
  .sign-in-page .sign-in-hero-inner,
  .sign-in-page .sign-in-content {
    width: 100%; max-width: 560px; margin-left: auto; margin-right: auto;
    padding-left: 2rem; padding-right: 2rem; box-sizing: border-box;
  }
  .sign-in-hero-title { color: var(--text-primary); margin: 0 0 0.5rem; font-size: 1.75rem; }
  .page-hero-signin .lead { margin: 0; color: var(--text-secondary); }
  .sign-in-content { padding-bottom: 3rem; }
  .back-link a { color: var(--accent-teal); text-decoration: none; }
  .auth-form label { display: block; margin-top: 1rem; color: var(--text-secondary); font-size: 0.9rem; }
  .auth-form input {
    width: 100%; max-width: 400px; padding: 12px 16px; margin-top: 0.25rem;
    font-family: var(--font-mono); font-size: 0.9rem; border: 1px solid var(--border-color);
    border-radius: 8px; background: var(--bg-tertiary); color: var(--text-primary);
  }
  .auth-form input:focus-visible { outline: 2px solid var(--accent-teal); outline-offset: 2px; }
  .auth-form .form-hint { font-size: 0.85rem; color: var(--text-tertiary); margin: 0.25rem 0 0; }
  .auth-form .link-btn { background: none; border: none; padding: 0; color: var(--accent-teal); cursor: pointer; font-size: inherit; }
  .auth-form .link-btn:hover { text-decoration: underline; }
  .auth-form button[type="submit"] {
    margin-top: 1.25rem; padding: 0.6rem 1.2rem; font-size: 1rem; font-weight: 600; border: none; border-radius: 6px;
    background: linear-gradient(135deg, var(--accent-teal), var(--accent-cyan)); color: var(--bg-primary); cursor: pointer;
  }
  .auth-form button:disabled { opacity: 0.6; cursor: not-allowed; }
  .form-message { margin-top: 1rem; min-height: 1.5em; font-size: 0.95rem; }
  .form-message--success { color: var(--success-color, #22c55e) !important; }
  .form-message--error { color: var(--error-color, #f87171) !important; }
  .section { margin-top: 2rem; }
  .section a { color: var(--accent-teal); }
</style>

---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Register — Testnet Portal"
  description="Choose your role: developer, user, or node operator. Register for the Boing Network testnet."
>
  <article class="portal-page choose-role-page page-wrap-full">
    <header class="page-hero-full">
      <div class="page-wrap-inner" style="max-width: 720px;">
        <span class="stage-badge-global">Testnet</span>
        <p class="back-link"><a href="/testnet">← Dashboard</a> · <a href="/">Boing Network</a></p>
        <h1>Register for the testnet</h1>
        <p class="lead">
          Choose your role to open a registration form tailored to you. One account per role; you can update your role later.
        </p>
      </div>
    </header>
    <div class="page-wrap-inner register-content" style="max-width: 720px;">
      <a href="/testnet/register/developer" class="role-option">
        <span class="role-title">Developer</span>
        <span class="role-desc">Build dApps, register contracts, qualify for grants and the dApp incentive pool.</span>
        <span class="role-cta">Register as developer →</span>
      </a>
      <a href="/testnet/register/user" class="role-option">
        <span class="role-title">User</span>
        <span class="role-desc">Use the faucet, complete quests, share feedback. Earn user rewards.</span>
        <span class="role-cta">Register as user →</span>
      </a>
      <a href="/testnet/register/operator" class="role-option">
        <span class="role-title">Node operator / Miner</span>
        <span class="role-desc">Run a validator, join the leaderboard, earn testnet BOING and mainnet recognition.</span>
        <span class="role-cta">Register as operator →</span>
      </a>
    </div>

    <section class="section">
      <p><a href="/testnet">← Dashboard</a> · <a href="/">Back to Boing Network</a></p>
    </section>
    </div>
  </article>
</Layout>

<style>
  .portal-page { padding: 0; margin: 0; }
  .register-content { padding-bottom: 3rem; }
  .back-link { margin-bottom: 1rem; }
  .back-link a { color: var(--accent-teal); }
  .page-hero-full .lead { color: var(--text-secondary); margin-bottom: 0; }
  .register-content .lead { margin-bottom: 2rem; }
  .role-chooser { display: flex; flex-direction: column; gap: 1rem; }
  .role-option {
    display: flex;
    flex-direction: column;
    padding: 1.25rem 1.5rem;
    background: rgba(30,41,59,0.35);
    border: 1px solid rgba(34,211,238,0.2);
    border-radius: 1rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
  }
  .role-option:hover {
    border-color: rgba(34,211,238,0.5);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(6,182,212,0.2);
  }
  .role-title { font-size: 1.15rem; font-weight: 600; color: var(--text-primary); margin-bottom: 0.35rem; }
  .role-desc { font-size: 0.9rem; color: var(--text-secondary); margin-bottom: 0.75rem; line-height: 1.4; }
  .role-cta { font-size: 0.9rem; color: var(--accent-teal); font-weight: 500; }
  .section { margin-top: 2rem; }
</style>

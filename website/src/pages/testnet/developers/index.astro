---
import Layout from '../../../layouts/Layout.astro';
import HubNav from '../../../components/HubNav.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import '../../../styles/hub-common.css';
---

<Layout
  title="Developers — Testnet Portal"
  description="Boing Network testnet: developer community, dApp registration, and success-based dApp incentive pool."
>
  <article class="portal-page role-hub developers-hub hub-page hub-developer" data-hub="developer">
    <script is:inline src="/portal-session.js"></script>
    <HubNav hub="developer" current="index" />
    <Breadcrumbs items={[{ label: 'Dashboard', href: '/testnet' }, { label: 'Developer Hub' }]} />

    <div class="hub-page-main">
    <div id="wrong-role-banner" class="wrong-role-banner" style="display: none;"></div>

    <div class="hub-hero fade-in-up">
      <h1>Developer Hub</h1>
      <p class="lead">
        Build dApps on testnet, register for incentive tracking, and qualify for grants. This hub is for <strong>developers</strong> only. At mainnet, a dedicated portion of the ecosystem pool rewards successful dApps (success-based, value cap per dApp).
      </p>
      <div class="hub-ctas" id="hub-ctas">
        <a href="/testnet/register/developer" class="btn btn-primary">Register as developer</a>
        <a href="/testnet/sign-in" class="btn btn-secondary">Sign in</a>
        <a href="/testnet/developers/dashboard" class="btn btn-secondary">Go to dashboard</a>
      </div>
    </div>

    <section class="section steps-section fade-in-up delay-1">
      <h2>Your journey</h2>
      <ol class="steps-list steps-list--numbered">
        <li><strong>Register</strong> — Add your account ID and optional GitHub/Discord on the <a href="/testnet/register/developer">developer registration</a> page.</li>
        <li><strong>Get testnet BOING</strong> — Use the <a href="/network/faucet">faucet</a> for gas and deployment.</li>
        <li><strong>Build & deploy</strong> — Follow the <a href="/developers/quickstart">quickstart</a> (CLI, SDK). Deploy a contract.</li>
        <li><strong>Register your dApp</strong> — Add your contract on the <a href="/testnet/developers/dashboard">Dashboard</a> (or use <code>boing_registerDappMetrics</code> at mainnet) to track it for incentives.</li>
      </ol>
    </section>

    <section class="section fade-in-up delay-2">
      <h2>dApp incentive pool</h2>
      <p>
        A portion of the <strong>Community & Grants</strong> allocation is reserved for <strong>successful dApps</strong>: rewards are based on usage (e.g. fees generated), with a <strong>per-dApp value cap</strong> per epoch. Testnet participation qualifies you for grants and for inclusion in this ecosystem at mainnet. See
        <a href="/pdfs/BOING-BLOCKCHAIN-DESIGN-PLAN.pdf" target="_blank" rel="noopener">BOING-BLOCKCHAIN-DESIGN-PLAN (PDF)</a>
        and
        <a href="/pdfs/DEVELOPMENT-AND-ENHANCEMENTS.pdf" target="_blank" rel="noopener">DEVELOPMENT-AND-ENHANCEMENTS (PDF)</a>.
      </p>
      <p><a href="/testnet/developers/dashboard" class="btn btn-secondary">Open dashboard</a> · <a href="/testnet/developers/resources" class="btn btn-secondary">Resources</a></p>
    </section>
    </div>
  </article>
</Layout>

<script is:inline src="/portal-session.js"></script>
<script define:vars={{ expectedRole: 'developer' }}>
  (function () {
    var session = window.BoingPortalSession && window.BoingPortalSession.getSession();
    var authEl = document.getElementById('portal-auth');
    var wrongBanner = document.getElementById('wrong-role-banner');
    var hubCtas = document.getElementById('hub-ctas');

    function renderAuth() {
      if (!authEl) return;
      if (!session) {
        authEl.innerHTML = '<a href="/testnet/sign-in" class="auth-link">Sign in</a>';
        return;
      }
      var short = window.BoingPortalSession ? window.BoingPortalSession.shortAccount(session.account_id_hex) : session.account_id_hex;
      var path = window.BoingPortalSession ? window.BoingPortalSession.roleAppPath(session.role) : '';
      if (session.role !== expectedRole) {
        authEl.innerHTML = 'Signed in as <span class="account-short">' + short + '</span> · <a href="' + path + '">Go to my hub</a> · <button type="button" id="portal-signout" class="auth-signout">Logout</button>';
        if (wrongBanner) {
          wrongBanner.style.display = 'block';
          wrongBanner.innerHTML = 'You\'re signed in as <strong>' + session.role + '</strong>. <a href="' + path + '">Go to your dashboard</a> or sign out below.';
        }
        if (hubCtas) hubCtas.style.display = 'flex';
      } else {
        authEl.innerHTML = 'Signed in as <span class="account-short">' + short + '</span> · <button type="button" id="portal-signout" class="auth-signout">Logout</button>';
        if (wrongBanner) wrongBanner.style.display = 'none';
        if (hubCtas) hubCtas.style.display = 'none';
      }
      var so = document.getElementById('portal-signout');
      if (so) so.addEventListener('click', function () {
        if (window.BoingPortalSession && window.BoingPortalSession.logout) window.BoingPortalSession.logout();
        else { try { localStorage.removeItem('boing_portal_session'); } catch(_){} window.location.href = '/'; }
      });
    }
    renderAuth();
  })();
</script>

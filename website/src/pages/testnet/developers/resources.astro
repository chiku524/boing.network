---
import Layout from '../../../layouts/Layout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import HubNav from '../../../components/HubNav.astro';
import Icon from '../../../components/Icon.astro';
import '../../../styles/hub-common.css';
---

<Layout
  title="Resources — Developer Hub — Testnet Portal"
  description="Quickstart, faucet, and RPC for Boing Network testnet developers."
>
  <article class="portal-page role-hub developers-hub hub-page hub-developer" data-hub="developer">
    <script is:inline src="/portal-session.js"></script>
    <Breadcrumbs items={[{ label: 'Testnet Portal', href: '/testnet' }, { label: 'Developer Hub', href: '/testnet/developers' }, { label: 'Resources' }]} />
    <div class="hub-page-main">
    <HubNav hub="developer" current="resources" />
      <section class="section fade-in-up">
      <h1>Resources</h1>
      <p class="muted">Links and docs to build and deploy on testnet.</p>
      <ul class="resources-list hub-list-animate">
        <li>
          <span class="resource-icon"><Icon name="rocket" size={22} /></span>
          <a href="/developers/quickstart">Quickstart</a>
          <p class="desc">CLI, SDK, local dev</p>
        </li>
        <li>
          <span class="resource-icon"><Icon name="network" size={22} /></span>
          <a href="/testnet/join">Join Testnet</a>
          <p class="desc">Bootnodes, faucet</p>
        </li>
        <li>
          <span class="resource-icon"><Icon name="faucet" size={22} /></span>
          <a href="/faucet">Faucet</a>
          <p class="desc">Get testnet BOING</p>
        </li>
        <li>
          <span class="resource-icon"><Icon name="link" size={22} /></span>
          <a href="/pdfs/RPC-API-SPEC.pdf" target="_blank" rel="noopener">RPC API (PDF)</a>
          <p class="desc"><code>boing_registerDappMetrics</code></p>
        </li>
        <li>
          <span class="resource-icon"><Icon name="link" size={22} /></span>
          <a href="https://github.com/Boing-Network/boing.network/blob/main/docs/BOING-CANONICAL-DEPLOY-ARTIFACTS.md" target="_blank" rel="noopener">Canonical deploy artifacts</a>
          <p class="desc">Pinned minimal &amp; secured fungible bytecode, SDK env keys</p>
        </li>
        <li>
          <span class="resource-icon"><Icon name="link" size={22} /></span>
          <a href="https://github.com/Boing-Network/boing.network/blob/main/docs/BOING-REFERENCE-TOKEN.md" target="_blank" rel="noopener">Reference token layout</a>
          <p class="desc">Calldata, secured template admin selectors</p>
        </li>
      </ul>
    </section>

    <section class="section fade-in-up delay-1">
      <h2>dApp incentive pool</h2>
      <p>
        A portion of the <strong>Community & Grants</strong> allocation is reserved for <strong>successful dApps</strong>: rewards are based on usage (e.g. fees generated), with a <strong>per-dApp value cap</strong> per epoch. See
        <a href="/pdfs/BOING-BLOCKCHAIN-DESIGN-PLAN.pdf" target="_blank" rel="noopener">BOING-BLOCKCHAIN-DESIGN-PLAN (PDF)</a>
        and
        <a href="/pdfs/DEVELOPMENT-AND-ENHANCEMENTS.pdf" target="_blank" rel="noopener">DEVELOPMENT-AND-ENHANCEMENTS (PDF)</a>.
      </p>
    </section>
  </div>
  </article>
</Layout>

<script is:inline src="/portal-session.js"></script>
<script>
  (function () {
    var expectedRole = 'developer';
    var session = window.BoingPortalSession && window.BoingPortalSession.getSession();
    var authEl = document.getElementById('portal-auth');
    if (session && session.role !== expectedRole) {
      var path = window.BoingPortalSession ? window.BoingPortalSession.roleAppPath(session.role) : '/testnet';
      window.location.href = path;
      return;
    }
    function renderAuth() {
      if (!authEl) return;
      if (!session) {
        authEl.innerHTML = '<a href="/testnet/sign-in" class="auth-link">Sign in</a>';
        return;
      }
      var short = window.BoingPortalSession ? window.BoingPortalSession.shortAccount(session.account_id_hex) : session.account_id_hex;
      authEl.innerHTML = 'Signed in as <span class="account-short">' + short + '</span> · <button type="button" id="portal-signout" class="auth-signout">Logout</button>';
      var so = document.getElementById('portal-signout');
      if (so) so.addEventListener('click', function () {
        if (window.BoingPortalSession && window.BoingPortalSession.logout) window.BoingPortalSession.logout();
        else { try { localStorage.removeItem('boing_portal_session'); } catch(_){} window.location.href = '/'; }
      });
    }
    renderAuth();
  })();
</script>

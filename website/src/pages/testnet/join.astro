---
import Layout from '../../layouts/Layout.astro';
import Icon from '../../components/Icon.astro';
import CopyButton from '../../components/CopyButton.astro';
import {
  TESTNET_RPC_URL,
  BOOTNODES,
  isTestnetLive,
  CANONICAL_NATIVE_CP_POOL_ACCOUNT_ID_HEX,
  CANONICAL_NATIVE_AMM_LP_VAULT_ACCOUNT_ID_HEX,
  CANONICAL_NATIVE_LP_SHARE_TOKEN_ACCOUNT_ID_HEX,
} from '../../config/testnet';
---

<Layout
  title="Join Testnet"
  description="Boing Network testnet: run a node, get testnet BOING from the faucet, and join as a validator."
>
  <article class="page-wrap-full">
    <header class="page-hero-full">
      <div class="page-wrap-inner">
        <span class="stage-badge-global">Testnet</span>
        <h1 class="page-title"><Icon name="network" size={32} class="title-icon" /> Join the Testnet</h1>
        <p class="lead">
          Run a node, get testnet BOING from the faucet, and participate as a validator or developer. Everything you need is below — or jump to dedicated pages for <strong>Bootnodes</strong>, <strong>Single vs multi-node</strong>, and the <strong>Faucet</strong>.
        </p>
      </div>
    </header>
    <div class="page-wrap-inner testnet-content">
    <div class="dedicated-cards">
      <a href="/testnet" class="dedicated-card featured card-reveal"><span class="card-icon"><Icon name="portal" size={28} /></span>
        <h2>Dashboard</h2>
        <p>Choose your path: developer, user, or node operator. Each role has its own hub with registration, dashboard, and resources.</p>
        <span class="card-arrow">Open portal →</span>
      </a>
      <a href="/single-vs-multi" class="dedicated-card card-reveal">
        <span class="card-icon"><Icon name="node" size={28} /></span>
        <h2>Single node vs multi-node</h2>
        <p>When to run alone vs joining the public testnet. Commands and comparison.</p>
        <span class="card-arrow">Read more →</span>
      </a>
      <a href="/bootnodes" class="dedicated-card card-reveal">
        <span class="card-icon"><Icon name="network" size={28} /></span>
        <h2>Bootnodes</h2>
        <p>What bootnodes are, how to use them, and where to get the official list.</p>
        <span class="card-arrow">Read more →</span>
      </a>
      <a href="/faucet" class="dedicated-card featured card-reveal">
        <span class="card-icon"><Icon name="faucet" size={28} /></span>
        <h2>Faucet</h2>
        <p>Get testnet BOING for gas and staking. One request per account per 60 seconds.</p>
        <span class="card-arrow">Get testnet BOING →</span>
      </a>
      <a href="/testnet/users" class="dedicated-card card-reveal">
        <span class="card-icon"><Icon name="quest" size={28} /></span>
        <h2>Community Quests (Users)</h2>
        <p>Complete quests in the Testnet Portal to qualify for user rewards. Faucet, first tx, feedback, and more.</p>
        <span class="card-arrow">Quests in portal →</span>
      </a>
    </div>

    <section class="section" id="quick-start">
      <h2><Icon name="rocket" size={22} class="section-icon" /> Quick start</h2>
      <ol>
        <li>Build: <code>cargo build --release</code></li>
        <li>Run a single node (validator): <code>./target/release/boing-node --validator --rpc-port 8545</code></li>
        <li>Or join the testnet (when bootnodes are live): <code>--p2p-listen /ip4/0.0.0.0/tcp/4001 --bootnodes &lt;BOOTNODE_LIST&gt;</code></li>
        <li>Get testnet BOING from the <a href="/faucet">faucet</a>.</li>
      </ol>
    </section>

    <section class="section" id="single-vs-multi">
      <h2>Single node vs multi-node</h2>
      <p>Brief summary. For the full guide, see <a href="/single-vs-multi">Single node vs multi-node</a>.</p>
      <ul>
        <li><strong>Single node</strong> — Run without P2P. Good for local dev. No bootnodes needed.</li>
        <li><strong>Multi-node testnet</strong> — Run with <code>--p2p-listen</code> and <code>--bootnodes</code> to join the public testnet.</li>
      </ul>
    </section>

    <section class="section" id="endpoints">
      <h2>Public testnet endpoints</h2>
      {isTestnetLive ? (
        <>
          <p><strong>RPC URL (faucet and submissions):</strong></p>
          <div class="copy-wrapper rpc-copy" data-copy-value={TESTNET_RPC_URL}>
            <code class="rpc-url-display">{TESTNET_RPC_URL}</code>
            <CopyButton label="Copy URL" copiedLabel="Copied!" />
          </div>
          {BOOTNODES.length > 0 && (
            <>
              <p><strong>Bootnodes:</strong> use with <code>--bootnodes</code> (comma-separated)</p>
              <pre class="code-block"><code>{BOOTNODES.join("\n")}</code></pre>
            </>
          )}
        </>
      ) : (
        <p>Once the testnet is live, the official RPC URL and bootnode list will appear here. Until then, use <code>http://127.0.0.1:8545</code> for local testing and run a <a href="/single-vs-multi">local multi-node</a> setup.</p>
      )}
    </section>

    <section class="section" id="native-amm-pool">
      <h2>Native AMM pool (chain 6913)</h2>
      <p>
        Integrators and <a href="https://boing.finance" target="_blank" rel="noopener noreferrer">boing.finance</a> use this
        <strong>canonical constant-product pool</strong> account id on public testnet. Full RPC and storage layout:
        <a href="https://github.com/Boing-Network/boing.network/blob/main/docs/RPC-API-SPEC.md#native-constant-product-amm-chain-6913--integration-note" target="_blank" rel="noopener noreferrer">RPC-API-SPEC (GitHub)</a>
        · <a href="/pdfs/RPC-API-SPEC.pdf" target="_blank" rel="noopener">RPC-API-SPEC (PDF)</a>.
      </p>
      <p><strong>Pool <code>AccountId</code> (copy for SDK / env):</strong></p>
      <div class="copy-wrapper rpc-copy" data-copy-value={CANONICAL_NATIVE_CP_POOL_ACCOUNT_ID_HEX}>
        <code class="rpc-url-display pool-id-display">{CANONICAL_NATIVE_CP_POOL_ACCOUNT_ID_HEX}</code>
        <CopyButton label="Copy pool id" copiedLabel="Copied!" />
      </div>
      <p class="muted small-print">
        Ops smoke (optional): <code>npm run check-canonical-pool</code> from the <a href="https://github.com/Boing-Network/boing.network" target="_blank" rel="noopener noreferrer">boing.network</a> repo root — verifies <code>boing_getContractStorage</code> against this pool on <code>BOING_RPC_URL</code>.
      </p>
    </section>

    <section class="section" id="native-lp-vault-share">
      <h2>Native LP vault &amp; share token (chain 6913)</h2>
      <p>
        Optional <strong>CREATE2</strong> contracts for the wrapped-LP path (vault + transferable share token). Same canonical deployer and bytecode as
        <a href="https://github.com/Boing-Network/boing.network/blob/main/scripts/canonical-testnet-dex-predicted.json" target="_blank" rel="noopener noreferrer"><code>canonical-testnet-dex-predicted.json</code></a>.
        Operators run <code>npm run deploy-native-dex-lp-aux-contracts</code> from the repo, then <strong>set_minter_once</strong> (vault → minter) and vault <strong>configure(pool, share)</strong> — see
        <a href="https://github.com/Boing-Network/boing.network/blob/main/docs/NATIVE-AMM-LP-VAULT.md" target="_blank" rel="noopener noreferrer">NATIVE-AMM-LP-VAULT</a> /
        <a href="https://github.com/Boing-Network/boing.network/blob/main/docs/NATIVE-LP-SHARE-TOKEN.md" target="_blank" rel="noopener noreferrer">NATIVE-LP-SHARE-TOKEN</a>.
      </p>
      <p><strong>LP vault <code>AccountId</code>:</strong></p>
      <div class="copy-wrapper rpc-copy" data-copy-value={CANONICAL_NATIVE_AMM_LP_VAULT_ACCOUNT_ID_HEX}>
        <code class="rpc-url-display pool-id-display">{CANONICAL_NATIVE_AMM_LP_VAULT_ACCOUNT_ID_HEX}</code>
        <CopyButton label="Copy vault id" copiedLabel="Copied!" />
      </div>
      <p><strong>LP share token <code>AccountId</code>:</strong></p>
      <div class="copy-wrapper rpc-copy" data-copy-value={CANONICAL_NATIVE_LP_SHARE_TOKEN_ACCOUNT_ID_HEX}>
        <code class="rpc-url-display pool-id-display">{CANONICAL_NATIVE_LP_SHARE_TOKEN_ACCOUNT_ID_HEX}</code>
        <CopyButton label="Copy share token id" copiedLabel="Copied!" />
      </div>
    </section>

    <section class="section" id="bootnodes">
      <h2>Bootnodes</h2>
      <p>Bootnodes are stable peer addresses your node dials to join the testnet. Full details: <a href="/bootnodes">Bootnodes</a>.</p>
      {!isTestnetLive && <p><em>Until the testnet is live, run a local multi-node setup by using the first node's address as <code>--bootnodes</code> for the second.</em></p>}
    </section>

    <section class="section" id="faucet">
      <h2>Faucet</h2>
      <p>Get testnet BOING for gas and staking on the dedicated faucet page.</p>
      <a href="/faucet" class="cta-link">Go to Faucet →</a>
    </section>

    <section class="section" id="vibeminer">
      <h2>One-click mining (VibeMiner)</h2>
      <p>
        Prefer a desktop UI? <strong>VibeMiner</strong> offers one-click mining/validating for Boing. See
        <a href="/pdfs/VIBEMINER-INTEGRATION.pdf" target="_blank" rel="noopener">VIBEMINER-INTEGRATION (PDF)</a>.
        The live app reads <a href="/api/networks">/api/networks</a> (JSON): <code>boing-devnet</code> (Windows), <code>boing-devnet-linux</code>, and <code>boing-devnet-macos</code> — each includes <code>platform</code>, download URL, and command template.
      </p>
      <p class="muted networks-api-line" id="networks-api-status" aria-live="polite">Checking network listing…</p>
    </section>

    <section class="section incentivized-callout" id="incentivized-callout">
      <h2>Incentivized testnet</h2>
      <p>When we run an incentivized testnet (validators, developers, and users can earn rewards), register in the <a href="/testnet">Testnet Portal</a> and use the same setup: join with bootnodes, use the faucet, and stake. Users complete <a href="/testnet/users">quests</a> in the portal. For launch readiness and rules, see <a href="/pdfs/TESTNET.pdf" target="_blank" rel="noopener">Testnet doc (PDF)</a>. Check announcements for the current phase.</p>
    </section>

    <section class="section">
      <h2>Docs</h2>
      <ul class="docs-quick-links">
        <li><a href="/docs/getting-started">Getting started</a></li>
        <li><a href="/pdfs/TESTNET.pdf" target="_blank" rel="noopener">TESTNET (PDF)</a> — Full testnet guide</li>
        <li><a href="/pdfs/RUNBOOK.pdf" target="_blank" rel="noopener">RUNBOOK (PDF)</a> — Node setup and RPC</li>
      </ul>
    </section>
    </div>
  </article>
</Layout>

<style>
  .testnet-content { padding-bottom: 3rem; }
  .page-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }
  .title-icon { color: var(--accent-teal); flex-shrink: 0; }
  .testnet-page h1 { color: var(--text-primary); }
  .lead { color: var(--text-secondary); font-size: 1.1rem; }
  .dedicated-cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin: 2rem 0; }
  .dedicated-card {
    animation: card-reveal 0.55s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    opacity: 0;
    transform: translateY(20px);
  }
  .dedicated-card:nth-child(1) { animation-delay: 0.05s; }
  .dedicated-card:nth-child(2) { animation-delay: 0.12s; }
  .dedicated-card:nth-child(3) { animation-delay: 0.19s; }
  .dedicated-card:nth-child(4) { animation-delay: 0.26s; }
  .dedicated-card:nth-child(5) { animation-delay: 0.33s; }
  @keyframes card-reveal { to { opacity: 1; transform: translateY(0); } }
  .dedicated-card:hover .card-icon {
    transform: scale(1.08);
  }
  .card-icon {
    display: block;
    margin-bottom: 0.75rem;
    color: var(--accent-teal);
    transition: transform 0.25s ease;
  }
  @media (prefers-reduced-motion: reduce) {
    .dedicated-card { animation: none; opacity: 1; transform: none; }
    .dedicated-card:hover .card-icon { transform: none; }
  }
  .dedicated-card {
    display: flex;
    flex-direction: column;
    position: relative;
    padding: 1.25rem;
    background: rgba(30,41,59,0.35);
    border: 1px solid rgba(34,211,238,0.2);
    border-radius: 1rem;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
  }
  .dedicated-card:hover { border-color: rgba(34,211,238,0.5); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(6,182,212,0.2); }
  .dedicated-card.featured { border-color: rgba(34,211,238,0.4); background: rgba(6,182,212,0.06); }
  .dedicated-card h2 { font-size: 1.1rem; margin: 0 0 0.5rem; color: var(--text-primary); }
  .dedicated-card p { font-size: 0.9rem; color: var(--text-secondary); margin: 0; line-height: 1.4; flex: 1; min-height: 0; }
  .card-arrow {
    display: inline-block;
    margin-top: 1rem;
    font-size: 0.8rem;
    color: var(--accent-teal);
    font-weight: 500;
  }
  .section-icon { vertical-align: middle; margin-right: 0.35rem; color: var(--accent-teal); }
  .section { margin-top: 2rem; }
  .section h2 {
    display: flex;
    align-items: center;
    font-size: 1.25rem;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }
  .section p, .section li { color: var(--text-secondary); }
  .section code { background: rgba(255,255,255,0.08); padding: 0.15rem 0.4rem; border-radius: 4px; font-size: 0.9em; }
  .section ol, .section ul { margin: 0.5rem 0 0 1.2rem; }
  .docs-quick-links { list-style: none; padding-left: 0; }
  .docs-quick-links li { margin-bottom: 0.5rem; }
  .docs-quick-links a { color: var(--accent-teal); font-weight: 500; }
  .cta-link { display: inline-block; margin-top: 0.5rem; color: var(--accent-teal); font-weight: 600; }
  .incentivized-callout { background: rgba(34,211,238,0.06); border: 1px solid rgba(34,211,238,0.25); border-radius: 0.75rem; padding: 1.25rem; }
  .incentivized-callout a { color: var(--accent-teal); font-weight: 600; }
  .code-block { background: rgba(0,0,0,0.3); border: 1px solid rgba(34,211,238,0.2); border-radius: 8px; padding: 1rem; overflow-x: auto; font-size: 0.85rem; }
  .code-block code { background: none; padding: 0; }
  @media (prefers-reduced-motion: reduce) { .dedicated-card:hover { transform: none; } }
  .rpc-copy {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: 0.25rem;
  }
  .rpc-copy .rpc-url-display {
    font-size: 0.9rem;
    padding: 0.35rem 0.5rem;
    background: rgba(0,0,0,0.25);
    border-radius: 6px;
  }
  .rpc-copy .pool-id-display {
    word-break: break-all;
    max-width: min(100%, 42rem);
  }
  .small-print { font-size: 0.85rem; margin-top: 0.5rem; }
  @media (max-width: 640px) {
    .testnet-content { padding-bottom: 2rem; }
    .dedicated-cards { margin: 1.5rem 0; gap: 0.75rem; }
    .dedicated-card { padding: 1rem; }
    .section { margin-top: 1.5rem; }
    .code-block { font-size: 0.8rem; padding: 0.75rem; }
  }
  @media (max-width: 375px) {
    .dedicated-cards { min-width: 0; }
    .section { margin-top: 1.25rem; }
  }
  .networks-api-line { font-size: 0.9rem; margin-top: 0.75rem; }
</style>

<script is:inline>
  (function () {
    var el = document.getElementById('networks-api-status');
    if (!el) return;
    fetch('/api/networks', { credentials: 'omit' })
      .then(function (r) {
        return r.json();
      })
      .then(function (data) {
        if (!data || !data.ok || !Array.isArray(data.networks)) {
          el.textContent = 'Could not read /api/networks.';
          return;
        }
        if (data.warning) {
          el.textContent = data.warning;
          return;
        }
        var want = ['boing-devnet', 'boing-devnet-linux', 'boing-devnet-macos'];
        var ready = [];
        var missing = [];
        want.forEach(function (id) {
          var n = data.networks.filter(function (x) {
            return x && x.id === id;
          })[0];
          if (!n) {
            missing.push(id);
            return;
          }
          if (n.node_download_url && n.node_command_template) ready.push(id);
          else missing.push(id);
        });
        if (missing.length === 0) {
          el.textContent =
            'Listings active: Windows, Linux, and macOS devnet packages are configured in /api/networks.';
        } else if (ready.length > 0) {
          el.textContent =
            'Partial: ' +
            ready.length +
            ' of 3 platform listings have download URL + command. Missing or incomplete: ' +
            missing.join(', ') +
            '.';
        } else {
          el.textContent =
            'Devnet entries exist but D1 has not set node_download_url / node_command_template yet (see website migrations).';
        }
      })
      .catch(function () {
        el.textContent = 'Could not load /api/networks.';
      });
  })();
</script>

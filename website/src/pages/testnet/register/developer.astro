---
import Layout from '../../../layouts/Layout.astro';
---

<Layout
  title="Register as developer — Testnet Portal"
  description="Register as a developer on the Boing Network testnet. Build dApps, track incentives, qualify for grants."
>
  <article class="portal-page register-page">
    <script is:inline src="/portal-session.js"></script>
    <script is:inline src="/portal-wallet.js"></script>
    <nav class="portal-nav">
      <a href="/testnet">Portal</a>
      <a href="/testnet/developers">Developers</a>
      <a href="/testnet/users">Users</a>
      <a href="/testnet/operators">Operators</a>
    </nav>

    <p class="breadcrumb"><a href="/testnet">Portal</a> → <a href="/testnet/developers">Developers</a> → Register</p>

    <div class="register-header fade-in-up">
      <h1>Register as a developer</h1>
      <p class="lead">
        Create your developer profile to track dApps, qualify for grants, and get recognized in the <strong>dApp incentive pool</strong> at mainnet. One account, one registration.
      </p>
    </div>

    <form id="register-form" class="register-form fade-in-up delay-1">
      <input type="hidden" name="role" value="developer" />

      <div class="auth-tabs" role="tablist" aria-label="How to provide account ID">
        <button type="button" class="auth-tab" role="tab" id="tab-wallet" aria-selected="true" aria-controls="panel-wallet" tabindex="0">Connect wallet</button>
        <button type="button" class="auth-tab" role="tab" id="tab-account" aria-selected="false" aria-controls="panel-account" tabindex="-1">Enter account ID</button>
      </div>
      <div id="panel-wallet" role="tabpanel" aria-labelledby="tab-wallet" class="auth-panel">
        <p class="auth-panel-desc">Connect your Boing wallet to fill your account ID below. You'll approve the connection in your wallet.</p>
        <p class="form-hint"><button type="button" id="connect-wallet-btn" class="link-btn auth-cta">Connect wallet</button><span id="wallet-actions"></span></p>
      </div>
      <div id="panel-account" role="tabpanel" aria-labelledby="tab-account" class="auth-panel hidden">
        <p class="auth-panel-desc">Enter your account ID (32-byte hex) below. You can copy it from your wallet or paste from elsewhere.</p>
      </div>

      <label for="account-id">Account ID (32-byte hex, with or without 0x) *</label>
      <input id="account-id" name="account_id_hex" type="text" placeholder="0x..." maxlength="66" required />

      <div id="register-password-fields" class="register-password-fields hidden">
        <label for="portal-password">Portal password (for sign-in with account ID later) *</label>
        <input id="portal-password" name="portal_password" type="password" placeholder="Min 8 characters" minlength="8" autocomplete="new-password" />
        <label for="confirm-password">Confirm password *</label>
        <input id="confirm-password" name="confirm_password" type="password" placeholder="Repeat password" minlength="8" autocomplete="new-password" />
      </div>

      <label for="email">Email (optional)</label>
      <input id="email" name="email" type="email" placeholder="you@example.com" />

      <label for="discord">Discord handle (optional)</label>
      <input id="discord" name="discord_handle" type="text" placeholder="username#1234" />

      <label for="github">GitHub username (optional)</label>
      <input id="github" name="github_username" type="text" placeholder="octocat" />

      <button type="submit" id="submit-btn">Register as developer</button>
      <p id="form-message" class="form-message" aria-live="polite"></p>
    </form>

    <section class="section">
      <p><a href="/testnet/developers">← Back to Developers</a></p>
    </section>
  </article>
</Layout>

<script>
  (function () {
    const form = document.getElementById('register-form');
    if (!form) return;
    const accountInput = form.querySelector('#account-id');
    const submitBtn = document.getElementById('submit-btn');
    const messageEl = document.getElementById('form-message');
    const connectBtn = document.getElementById('connect-wallet-btn');

    function switchTab(activeTabId) {
      var tabWallet = document.getElementById('tab-wallet');
      var tabAccount = document.getElementById('tab-account');
      var panelWallet = document.getElementById('panel-wallet');
      var panelAccount = document.getElementById('panel-account');
      var passwordFields = document.getElementById('register-password-fields');
      if (activeTabId === 'wallet') {
        if (tabWallet) { tabWallet.setAttribute('aria-selected', 'true'); tabWallet.setAttribute('tabindex', '0'); }
        if (tabAccount) { tabAccount.setAttribute('aria-selected', 'false'); tabAccount.setAttribute('tabindex', '-1'); }
        if (panelWallet) panelWallet.classList.remove('hidden');
        if (panelAccount) panelAccount.classList.add('hidden');
        if (passwordFields) passwordFields.classList.add('hidden');
        if (form.querySelector('#portal-password')) form.querySelector('#portal-password').removeAttribute('required');
        if (form.querySelector('#confirm-password')) form.querySelector('#confirm-password').removeAttribute('required');
      } else {
        if (tabAccount) { tabAccount.setAttribute('aria-selected', 'true'); tabAccount.setAttribute('tabindex', '0'); }
        if (tabWallet) { tabWallet.setAttribute('aria-selected', 'false'); tabWallet.setAttribute('tabindex', '-1'); }
        if (panelAccount) panelAccount.classList.remove('hidden');
        if (panelWallet) panelWallet.classList.add('hidden');
        if (passwordFields) passwordFields.classList.remove('hidden');
        if (form.querySelector('#portal-password')) form.querySelector('#portal-password').setAttribute('required', '');
        if (form.querySelector('#confirm-password')) form.querySelector('#confirm-password').setAttribute('required', '');
      }
    }
    var tabWalletBtn = document.getElementById('tab-wallet');
    var tabAccountBtn = document.getElementById('tab-account');
    if (tabWalletBtn) tabWalletBtn.addEventListener('click', function () { switchTab('wallet'); });
    if (tabAccountBtn) tabAccountBtn.addEventListener('click', function () { switchTab('account'); });

    function setMessage(text, isError = false, isSuccess = false) {
      if (messageEl) {
        messageEl.textContent = text;
        messageEl.classList.remove('form-message--error', 'form-message--success');
        if (isSuccess) messageEl.classList.add('form-message--success');
        else if (isError) messageEl.classList.add('form-message--error');
        messageEl.style.color = isError ? 'var(--error-color, #f87171)' : (isSuccess ? '' : 'var(--text-secondary)');
      }
    }
    function getProvider() {
      if (typeof window === 'undefined') return null;
      var w = window.BoingPortalWallet;
      return (w && w.getProvider && w.getProvider()) || window.boing || window.ethereum || null;
    }
    function providerMethod(primary, fallback) {
      return function (provider, params) {
        return provider.request({ method: primary, params: params || [] }).catch(function (err) {
          const msg = (err && err.message || '').toLowerCase();
          if (!fallback || primary === fallback || (msg.indexOf('not found') === -1 && msg.indexOf('unsupported') === -1)) throw err;
          return provider.request({ method: fallback, params: params || [] });
        });
      };
    }
    const requestAccounts = providerMethod('boing_requestAccounts', 'eth_requestAccounts');
    const signMessage = providerMethod('boing_signMessage', 'personal_sign');
    const getChainId = providerMethod('boing_chainId', 'eth_chainId');
    const switchChain = providerMethod('boing_switchChain', 'wallet_switchEthereumChain');
    function buildConnectMessage() {
      var origin = window.location.origin || '';
      var timestamp = new Date().toISOString();
      return 'Connect to Boing Portal\nOrigin: ' + origin + '\nTimestamp: ' + timestamp;
    }
    async function ensureTestnetChain(provider) {
      try {
        const chainId = await getChainId(provider, []);
        if (chainId && String(chainId).toLowerCase() === '0x1b01') return true;
        setMessage('Switching wallet to Boing Testnet…');
        await switchChain(provider, [{ chainId: '0x1b01' }]);
        return true;
      } catch (err) {
        setMessage('Please switch your wallet to Boing Testnet and try again.', true);
        return false;
      }
    }
    if (connectBtn) {
      connectBtn.addEventListener('click', async function () {
        const provider = getProvider();
        if (!provider) { setMessage('No Boing wallet found. Install Boing Express (boing.express) or a Boing-compatible wallet.', true); return; }
        connectBtn.disabled = true;
        setMessage('Connecting…');
        try {
          const ok = await ensureTestnetChain(provider);
          if (!ok) { connectBtn.disabled = false; return; }
          const accounts = await requestAccounts(provider, []);
          const address = Array.isArray(accounts) && accounts[0] ? accounts[0] : null;
          if (!address) {
            setMessage('No account selected.', true);
            connectBtn.disabled = false;
            return;
          }
          setMessage('Approve the connection in your wallet…');
          var connectMsg = buildConnectMessage();
          var signature = await signMessage(provider, [connectMsg, address]).catch(function (err) {
            if (err && (String(err.message || '').toLowerCase().indexOf('reject') !== -1 || String(err.message || '').toLowerCase().indexOf('denied') !== -1 || String(err.message || '').toLowerCase().indexOf('cancel') !== -1)) return null;
            throw err;
          });
          if (!signature || typeof signature !== 'string') {
            setMessage('Connection was not approved in your wallet. Please approve the request in your wallet to connect.', true);
            connectBtn.disabled = false;
            return;
          }
          if (accountInput) {
            accountInput.value = address;
            setMessage('Account filled. Complete the form below (no password needed for wallet sign-in).', false);
            var actions = document.getElementById('wallet-actions');
            if (actions) { actions.innerHTML = ' · <button type="button" class="link-btn" id="clear-account-btn">Clear account</button>'; }
            var clearBtn = document.getElementById('clear-account-btn');
            if (clearBtn) clearBtn.onclick = function () { accountInput.value = ''; setMessage(''); if (actions) actions.innerHTML = ''; };
          }
        } catch (err) {
          var msg = (window.BoingPortalWallet && window.BoingPortalWallet.normalizeWalletError && window.BoingPortalWallet.normalizeWalletError(err.message)) || err.message || 'Connection failed.';
          setMessage(msg, true);
        }
        connectBtn.disabled = false;
      });
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      let accountHex = (accountInput?.value || '').trim();
      const email = (form.querySelector('#email')?.value || '').trim() || undefined;
      const discordHandle = (form.querySelector('#discord')?.value || '').trim() || undefined;
      const githubUsername = (form.querySelector('#github')?.value || '').trim() || undefined;
      const password = (form.querySelector('#portal-password')?.value || '').trim();
      const confirmPassword = (form.querySelector('#confirm-password')?.value || '').trim();
      var isWalletTab = document.getElementById('panel-account').classList.contains('hidden');

      if (!accountHex) { setMessage('Please enter your account ID.', true); return; }
      if (!accountHex.startsWith('0x')) accountHex = '0x' + accountHex;
      if (accountHex.length !== 66) {
        setMessage('Account ID must be 32 bytes (64 hex chars + 0x).', true);
        return;
      }
      if (!isWalletTab) {
        if (password.length < 8) { setMessage('Portal password must be at least 8 characters.', true); return; }
        if (password !== confirmPassword) { setMessage('Passwords do not match.', true); return; }
      }

      if (submitBtn) submitBtn.disabled = true;
      setMessage('Submitting…');

      try {
        const res = await fetch('/api/portal/register', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            account_id_hex: accountHex,
            role: 'developer',
            password: isWalletTab ? undefined : password,
            email: email || undefined,
            discord_handle: discordHandle || undefined,
            github_username: githubUsername || undefined,
          }),
        });
        const data = await res.json().catch(() => ({}));

        if (res.ok && data.ok) {
          setMessage('Registered. Taking you to your hub…', false, true);
          messageEl?.classList.add('form-message--success');
          form.classList.add('register-form--success');
          try { localStorage.setItem('boing_portal_account', accountHex); } catch (_) {}
          if (window.BoingPortalSession) window.BoingPortalSession.setSession(accountHex, 'developer');
          setTimeout(() => { window.location.href = '/testnet/developers'; }, 600);
        } else if (res.status === 404 || res.status === 502) {
          setMessage('API not available yet. Please try again later or submit in Discord.', true);
        } else {
          setMessage(data.message || data.error || 'Registration failed.', true);
        }
      } catch (err) {
        setMessage('Network error. Try again or submit in Discord.', true);
      } finally {
        if (submitBtn) submitBtn.disabled = false;
      }
    });
  })();
</script>

<style>
  .portal-page { max-width: 560px; margin: 0 auto; padding: 2rem; }
  .portal-nav { display: flex; flex-wrap: wrap; gap: 0.5rem 1rem; margin-bottom: 1rem; padding-bottom: 1rem; border-bottom: 1px solid var(--border-color); }
  .portal-nav a { color: var(--text-secondary); font-weight: 500; transition: color 0.2s ease; }
  .portal-nav a:hover { color: var(--accent-teal); }
  .portal-nav a:focus-visible { outline: 2px solid var(--accent-teal); outline-offset: 2px; }
  .breadcrumb { font-size: 0.9rem; color: var(--text-tertiary); margin-bottom: 1rem; }
  .breadcrumb a { color: var(--accent-teal); }
  .register-header { margin-bottom: 1.5rem; }
  .lead { color: var(--text-secondary); margin-bottom: 1.5rem; }
  .register-form label { display: block; margin-top: 1rem; color: var(--text-secondary); font-size: 0.9rem; }
  .register-form label { display: block; margin-top: 1rem; color: var(--text-secondary); font-size: 0.9rem; }
  .register-form .form-hint { font-size: 0.85rem; color: var(--text-tertiary); margin: 0.25rem 0 0; }
  .register-form .link-btn { background: none; border: none; padding: 0; color: var(--accent-teal); cursor: pointer; font-size: inherit; }
  .register-form .link-btn.auth-cta { font-weight: 600; }
  .register-form .link-btn:hover { text-decoration: underline; }
  .register-form .auth-tabs { display: flex; gap: 0; margin-bottom: 1rem; border-bottom: 1px solid var(--border-color); }
  .register-form .auth-tab {
    padding: 0.5rem 1rem; font-size: 0.9rem; font-weight: 500; border: none; border-bottom: 2px solid transparent;
    margin-bottom: -1px; background: none; color: var(--text-secondary); cursor: pointer; border-radius: 6px 6px 0 0;
  }
  .register-form .auth-tab:hover { color: var(--text-primary); }
  .register-form .auth-tab[aria-selected="true"] { color: var(--accent-teal); border-bottom-color: var(--accent-teal); }
  .register-form .auth-tab:focus-visible { outline: 2px solid var(--accent-teal); outline-offset: 2px; }
  .register-form .auth-panel { margin-bottom: 1rem; }
  .register-form .auth-panel.hidden { display: none !important; }
  .register-form .auth-panel-desc { margin: 0 0 0.5rem; font-size: 0.9rem; color: var(--text-secondary); }
  .register-form .register-password-fields.hidden { display: none !important; }
  .register-form input[type="text"], .register-form input[type="email"], .register-form input[type="password"] {
    width: 100%; max-width: 400px; padding: 12px 16px; margin-top: 0.25rem;
    font-family: var(--font-mono); font-size: 0.9rem; border: 1px solid var(--border-color);
    border-radius: 8px; background: var(--bg-tertiary); color: var(--text-primary);
    transition: border-color 0.2s ease;
  }
  .register-form input:focus-visible {
    outline: 2px solid var(--accent-teal);
    outline-offset: 2px;
    border-color: rgba(124, 58, 237, 0.6);
  }
  .register-form button {
    margin-top: 1.25rem; padding: 0.6rem 1.2rem; font-size: 1rem; font-weight: 600; border: none; border-radius: 6px;
    background: linear-gradient(135deg, var(--accent-teal), var(--accent-cyan)); color: var(--bg-primary); cursor: pointer;
    transition: opacity 0.2s ease;
  }
  .register-form button:hover:not(:disabled) { opacity: 0.9; }
  .register-form button:focus-visible { outline: 2px solid var(--accent-teal); outline-offset: 2px; }
  .register-form button:disabled { opacity: 0.6; cursor: not-allowed; }
  .form-message { margin-top: 1rem; min-height: 1.5em; font-size: 0.95rem; }
  .form-message--success { color: var(--success-color, #22c55e) !important; font-weight: 500; }
  .form-message--success::before { content: '✓ '; }
  .form-message--error { color: var(--error-color, #f87171) !important; }
  .section { margin-top: 2rem; }
  .section a { color: var(--accent-teal); }
  .section a:focus-visible { outline: 2px solid var(--accent-teal); outline-offset: 2px; }
  .register-page .fade-in-up { animation: auth-fade-in-up 0.5s ease-out both; }
  .register-page .delay-1 { animation-delay: 0.08s; }
  @keyframes auth-fade-in-up {
    from { opacity: 0; transform: translateY(14px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .register-page .fade-in-up { animation: none; opacity: 1; transform: none; }
  }
</style>

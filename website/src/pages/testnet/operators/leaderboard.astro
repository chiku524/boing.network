---
import Layout from '../../../layouts/Layout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import HubNav from '../../../components/HubNav.astro';
import { TESTNET_RPC_URL, BOOTNODES, isTestnetLive } from '../../../config/testnet';
import '../../../styles/hub-common.css';
---

<Layout
  title="Leaderboard — Operator Hub — Testnet Portal"
  description="Node operator leaderboard and metrics on Boing Network testnet."
>
  <article class="portal-page role-hub operators-hub hub-page hub-operator" data-hub="node_operator">
    <script is:inline src="/portal-session.js"></script>
    <Breadcrumbs items={[{ label: 'Testnet Portal', href: '/testnet' }, { label: 'Operator Hub', href: '/testnet/operators' }, { label: 'Leaderboard' }]} />
    <div class="hub-page-main">
    <HubNav hub="operator" current="leaderboard" />
    <section class="section fade-in-up">
      <h1>Leaderboard</h1>
      <p class="muted">Blocks proposed and uptime will appear here once the testnet indexer is live. <a href="https://github.com/chiku524/boing.network/blob/main/docs/INDEXER-OPERATOR-STATS.md" target="_blank" rel="noopener">What to build to enable live stats</a>. <a href="/testnet/register/operator">Register as node operator</a> to be counted.</p>

      <div class="hub-metrics">
        <div class="hub-metric-card">
          <span class="value" id="leaderboard-operator-count">—</span>
          <span class="label">Operators</span>
        </div>
        <div class="hub-metric-card">
          <span class="value" id="leaderboard-total-blocks">—</span>
          <span class="label">Blocks (total)</span>
        </div>
        <div class="hub-metric-card">
          <span class="value" id="leaderboard-indexer-status">Soon</span>
          <span class="label">Indexer status</span>
        </div>
      </div>

      <table class="leaderboard-table hub-leaderboard-animate" aria-label="Operator leaderboard">
        <thead>
          <tr>
            <th>Rank</th>
            <th>Account</th>
            <th>Blocks proposed</th>
            <th>Uptime</th>
          </tr>
        </thead>
        <tbody id="leaderboard-tbody">
          <tr id="leaderboard-placeholder-row">
            <td colspan="4" style="text-align: center; color: var(--text-tertiary); padding: 2rem;">Loading…</td>
          </tr>
        </tbody>
      </table>
      <p class="leaderboard-placeholder-note" id="leaderboard-note">
        Leaderboard and per-operator metrics coming when indexer/RPC data is available. See <a href="/network/testnet">Join Testnet</a> for bootnodes and <a href="/pdfs/VIBEMINER-INTEGRATION.pdf" target="_blank" rel="noopener">VibeMiner (PDF)</a> for one-click setup.
      </p>
    </section>

    <section class="section fade-in-up delay-1">
      <h2>Your node</h2>
      <p>Run <code>boing-node</code> with P2P and bootnodes to join the public testnet. Stake testnet BOING (from the faucet) to participate in consensus.</p>
      {isTestnetLive ? (
        <>
          <p><strong>RPC:</strong> <code>{TESTNET_RPC_URL}</code></p>
          {BOOTNODES.length > 0 && (
            <>
              <p><strong>Bootnodes:</strong></p>
              <pre class="code-block"><code>{BOOTNODES.join("\n")}</code></pre>
            </>
          )}
        </>
      ) : (
        <p>Testnet endpoints will appear here when live. Until then, use <a href="/network/single-vs-multi">local multi-node</a> or run with placeholder bootnodes.</p>
      )}
    </section>
  </div>
  </article>
</Layout>

<script is:inline src="/portal-session.js"></script>
<script>
  (function () {
    var expectedRole = 'node_operator';
    var session = window.BoingPortalSession && window.BoingPortalSession.getSession();
    var authEl = document.getElementById('portal-auth');
    if (session && session.role !== expectedRole) {
      var path = window.BoingPortalSession ? window.BoingPortalSession.roleAppPath(session.role) : '/testnet';
      window.location.href = path;
      return;
    }
    function renderAuth() {
      if (!authEl) return;
      if (!session) {
        authEl.innerHTML = '<a href="/testnet/sign-in" class="auth-link">Sign in</a>';
        return;
      }
      var short = window.BoingPortalSession ? window.BoingPortalSession.shortAccount(session.account_id_hex) : session.account_id_hex;
      authEl.innerHTML = 'Signed in as <span class="account-short">' + short + '</span> · <button type="button" id="portal-signout" class="auth-signout">Logout</button>';
      var so = document.getElementById('portal-signout');
      if (so) so.addEventListener('click', function () {
        if (window.BoingPortalSession && window.BoingPortalSession.logout) window.BoingPortalSession.logout();
        else { try { localStorage.removeItem('boing_portal_session'); } catch(_){} window.location.href = '/'; }
      });
    }
    renderAuth();

    function shortAccount(hex) {
      if (!hex || hex.length < 20) return hex || '';
      return hex.slice(0, 10) + '…' + hex.slice(-6);
    }

    function formatUptime(first, last) {
      if (!first && !last) return '—';
      var f = first ? first.slice(0, 10) : '';
      var l = last ? last.slice(0, 10) : '';
      if (f && l) return f === l ? f : f + ' – ' + l;
      return f || l;
    }

    var tbody = document.getElementById('leaderboard-tbody');
    var placeholderRow = document.getElementById('leaderboard-placeholder-row');
    var operatorCountEl = document.getElementById('leaderboard-operator-count');
    var totalBlocksEl = document.getElementById('leaderboard-total-blocks');
    var indexerStatusEl = document.getElementById('leaderboard-indexer-status');
    var noteEl = document.getElementById('leaderboard-note');

    fetch('/api/portal/operator-leaderboard')
      .then(function (res) { return res.json().catch(function () { return {}; }); })
      .then(function (data) {
        if (!data.ok) {
          if (placeholderRow) placeholderRow.innerHTML = '<td colspan="4" style="text-align: center; color: var(--text-tertiary); padding: 2rem;">Unable to load leaderboard.</td>';
          return;
        }
        if (operatorCountEl) operatorCountEl.textContent = data.total_operators ?? 0;
        if (totalBlocksEl) totalBlocksEl.textContent = data.total_blocks ?? 0;
        if (indexerStatusEl) indexerStatusEl.textContent = (data.total_blocks > 0) ? 'Live' : 'Soon';

        var operators = data.operators || [];
        if (operators.length === 0) {
          if (placeholderRow) placeholderRow.innerHTML = '<td colspan="4" style="text-align: center; color: var(--text-tertiary); padding: 2rem;">Leaderboard data will appear when the indexer is live.</td>';
          return;
        }
        if (placeholderRow) placeholderRow.remove();
        operators.forEach(function (op) {
          var tr = document.createElement('tr');
          tr.className = 'hub-leaderboard-row';
          if (op.rank === 1) tr.classList.add('hub-leaderboard-row--gold');
          else if (op.rank === 2) tr.classList.add('hub-leaderboard-row--silver');
          else if (op.rank === 3) tr.classList.add('hub-leaderboard-row--bronze');
          tr.innerHTML =
            '<td>' + op.rank + '</td>' +
            '<td><code class="account-short" title="' + (op.proposer || '') + '">' + shortAccount(op.proposer) + '</code></td>' +
            '<td>' + op.blocks_proposed + '</td>' +
            '<td>' + formatUptime(op.first_block_at, op.last_block_at) + '</td>';
          if (tbody) tbody.appendChild(tr);
        });
        if (noteEl) noteEl.style.display = 'none';
      })
      .catch(function () {
        if (placeholderRow) placeholderRow.innerHTML = '<td colspan="4" style="text-align: center; color: var(--text-tertiary); padding: 2rem;">Leaderboard data will appear when the indexer is live.</td>';
      });
  })();
</script>

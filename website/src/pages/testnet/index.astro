---
import Layout from '../../layouts/Layout.astro';
import Icon from '../../components/Icon.astro';
import '../../styles/hub-common.css';
---

<Layout
  title="Dashboard — Boing Network Testnet"
  description="Boing Network testnet dashboard: sign in or register. Access your developer, community, or operator hub."
>
  <article class="portal-page portal-entry page-wrap-full">
    <script is:inline src="/portal-session.js"></script>
    <div class="portal-entry-inner page-wrap-inner">
    <div class="portal-hero fade-in-up">
      <h1 class="portal-hero-title"><Icon name="portal" size={36} class="title-icon" /> Dashboard</h1>
      <p class="lead portal-hero-lead fade-in-up delay-1">
        Sign in to open your hub, or register as a <strong>developer</strong>, <strong>community user</strong>, or <strong>node operator</strong>. Each hub has a <strong>My Dashboard</strong> (your data) and <strong>Community</strong> (leaderboards and hub-wide progress).
      </p>
      <div class="hero-ctas fade-in-up delay-2">
        <a href="/testnet/sign-in" class="btn btn-primary">Sign in</a>
        <a href="/testnet/register" class="btn btn-secondary">Register</a>
      </div>
    </div>

    <section class="section section-how-it-works fade-in-up delay-1" id="how-it-works">
      <h2>How it works</h2>
      <p class="muted">Get started in three steps. Choose your role, register once, then use your hub to track progress and earn.</p>
      <div class="testnet-how-it-works">
        <div class="testnet-how-it-works__connector" aria-hidden="true"></div>
        <div class="testnet-how-it-works__steps">
          <div class="testnet-step testnet-step--1">
            <span class="testnet-step__num" aria-hidden="true">1</span>
            <h3 class="testnet-step__title">Choose your role</h3>
            <p class="testnet-step__desc">Developer, Community user, or Node operator. Each has a dedicated hub.</p>
          </div>
          <div class="testnet-step testnet-step--2">
            <span class="testnet-step__num" aria-hidden="true">2</span>
            <h3 class="testnet-step__title">Register</h3>
            <p class="testnet-step__desc">Sign in with your wallet or account ID. One registration per role.</p>
          </div>
          <div class="testnet-step testnet-step--3">
            <span class="testnet-step__num" aria-hidden="true">3</span>
            <h3 class="testnet-step__title">Use your hub</h3>
            <p class="testnet-step__desc">My Dashboard for your stats, Community for leaderboards and quests.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="section section-glance fade-in-up delay-1" id="network-glance">
      <h2>Network at a glance</h2>
      <p class="muted">Live testnet activity. Numbers update when the API is connected.</p>
      <div class="testnet-glance" id="testnet-glance">
        <div class="testnet-glance__card">
          <span class="testnet-glance__value" id="glance-quests">—</span>
          <span class="testnet-glance__label">Quest completions</span>
        </div>
        <div class="testnet-glance__card">
          <span class="testnet-glance__value" id="glance-dapps">—</span>
          <span class="testnet-glance__label">dApps registered</span>
        </div>
      </div>
    </section>

    <section class="section section-role-cards fade-in-up delay-1" id="register-options">
      <h2>Register for a hub</h2>
      <p class="muted">Choose one role. After registration you're taken to that hub. In each hub: <strong>My Dashboard</strong> = your stats and registration; <strong>Community</strong> = leaderboards and hub-wide progress.</p>
      <div class="role-cards">
        <div class="role-card role-card--developer">
          <span class="role-card-icon" aria-hidden="true"><Icon name="code" size={28} /></span>
          <h3>Developer Hub</h3>
          <p>Build dApps, register contracts, qualify for grants and the dApp incentive pool.</p>
          <a href="/testnet/register/developer" class="card-arrow">Register as developer →</a>
          <p class="role-card-hub-links"><a href="/testnet/developers/dashboard">My Dashboard</a> · <a href="/testnet/developers/community">Community</a></p>
        </div>
        <div class="role-card role-card--user">
          <span class="role-card-icon" aria-hidden="true"><Icon name="quest" size={28} /></span>
          <h3>Community Hub</h3>
          <p>Use the faucet, complete quests, share feedback. Earn user rewards.</p>
          <a href="/testnet/register/user" class="card-arrow">Register as user →</a>
          <p class="role-card-hub-links"><a href="/testnet/users/dashboard">My Dashboard</a> · <a href="/testnet/users/community">Community</a></p>
        </div>
        <div class="role-card role-card--operator">
          <span class="role-card-icon" aria-hidden="true"><Icon name="node" size={28} /></span>
          <h3>Operator Hub</h3>
          <p>Run a node or miner, join the leaderboard, earn testnet BOING.</p>
          <a href="/testnet/register/operator" class="card-arrow">Register as operator →</a>
          <p class="role-card-hub-links"><a href="/testnet/operators/dashboard">My Dashboard</a> · <a href="/testnet/operators/leaderboard">Leaderboard</a></p>
        </div>
      </div>
    </section>

    <section class="section section-back">
      <p><a href="/" class="back-to-site">← Back to Boing Network</a></p>
    </section>
    </div>
  </article>
</Layout>

<script>
  (function () {
    var session = window.BoingPortalSession && window.BoingPortalSession.getSession();
    if (!session) return;
    var path = window.BoingPortalSession ? window.BoingPortalSession.roleAppPath(session.role) : '/testnet';
    if (path && path !== '/testnet') {
      window.location.href = path;
      return;
    }
  })();
</script>
<script>
  (function () {
    var questsEl = document.getElementById('glance-quests');
    var dappsEl = document.getElementById('glance-dapps');
    if (!questsEl && !dappsEl) return;
    function setQuests(n) {
      if (questsEl) questsEl.textContent = typeof n === 'number' ? n : '—';
    }
    function setDapps(n) {
      if (dappsEl) dappsEl.textContent = typeof n === 'number' ? n : '—';
    }
    Promise.all([
      fetch('/api/portal/quests-stats').then(function (r) { return r.json().catch(function () { return {}; }); }),
      fetch('/api/portal/dapps').then(function (r) { return r.json().catch(function () { return {}; }); })
    ]).then(function (results) {
      var quests = results[0];
      var dapps = results[1];
      if (quests.ok && quests.total_completions != null) setQuests(quests.total_completions);
      if (dapps.ok && Array.isArray(dapps.dapps)) setDapps(dapps.dapps.length);
    }).catch(function () {});
  })();
</script>

<style>
  .portal-page { padding: 0; margin: 0; width: 100%; }
  .portal-entry-inner {
    width: 100%;
    max-width: 100%;
    padding: 2rem 1.5rem 3rem;
    margin: 0 auto;
    box-sizing: border-box;
  }
  @media (min-width: 768px) {
    .portal-entry-inner { padding: 2.5rem 2rem 4rem; }
  }
  .portal-entry .portal-hero { margin-bottom: 2.5rem; text-align: center; }
  .portal-hero-title {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }
  .portal-hero-title .title-icon { color: var(--accent-teal); flex-shrink: 0; }
  .portal-hero .lead { color: var(--text-secondary); font-size: 1.05rem; margin-bottom: 1rem; max-width: 640px; margin-left: auto; margin-right: auto; }
  .portal-hero-lead { display: block; }
  .hero-ctas { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.25rem; justify-content: center; }
  .hero-ctas .btn {
    padding: 0.6rem 1.2rem; font-size: 1rem; text-decoration: none; font-weight: 600; border-radius: 6px;
    display: inline-block; transition: opacity 0.2s ease, box-shadow 0.2s ease;
  }
  .hero-ctas .btn-primary { background: linear-gradient(135deg, var(--accent-teal), var(--accent-cyan)); color: var(--bg-primary); }
  .hero-ctas .btn-secondary { background: rgba(124, 58, 237, 0.2); color: var(--accent-teal); border: 1px solid rgba(124, 58, 237, 0.4); }
  .hero-ctas .btn-secondary:hover { background: rgba(124, 58, 237, 0.3); }
  .hero-ctas .btn:focus-visible { outline: 2px solid var(--accent-teal); outline-offset: 2px; }

  .section { margin-top: 2.5rem; text-align: center; }
  .section h2 { font-size: 1.25rem; color: var(--text-primary); margin-bottom: 0.5rem; }
  .section p { color: var(--text-secondary); }
  .section .muted { max-width: 560px; margin-left: auto; margin-right: auto; }
  .muted { color: var(--text-tertiary); font-size: 0.95rem; margin-bottom: 1rem; }

  .role-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 1.5rem;
    max-width: 1200px;
    margin-left: auto;
    margin-right: auto;
    padding: 0 0.5rem;
  }
  @media (max-width: 900px) {
    .role-cards { grid-template-columns: 1fr; max-width: 420px; margin-left: auto; margin-right: auto; }
  }
  .role-card {
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    background: rgba(8, 13, 26, 0.6);
    border: 1px solid rgba(124, 58, 237, 0.25);
    border-radius: 1rem;
    text-decoration: none;
    color: inherit;
    position: relative;
    overflow: hidden;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .role-card .card-arrow {
    margin-top: auto;
    padding-top: 0.5rem;
    font-size: 0.8rem;
    color: var(--accent-teal);
    font-weight: 500;
    display: inline-block;
  }
  .role-card .card-arrow:hover { text-decoration: underline; }
  .role-card-hub-links {
    margin: 0.35rem 0 0;
    font-size: 0.78rem;
  }
  .role-card-hub-links a { color: var(--text-tertiary); }
  .role-card-hub-links a:hover { color: var(--accent-teal); }
  .role-card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 4px;
    border-radius: 4px 0 0 4px;
  }
  .role-card--developer::before { background: linear-gradient(180deg, #06b6d4, #22d3ee); }
  .role-card--user::before { background: linear-gradient(180deg, #fbbf24, #f59e0b); }
  .role-card--operator::before { background: linear-gradient(180deg, #7c3aed, #a78bfa); }
  .role-card:hover {
    border-color: rgba(124, 58, 237, 0.5);
    box-shadow: 0 8px 24px rgba(124, 58, 237, 0.15);
  }
  .role-card:focus-visible {
    outline: 2px solid var(--accent-teal);
    outline-offset: 2px;
  }
  .role-card-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    margin-bottom: 0.75rem;
    opacity: 0.9;
  }
  .role-card-icon :global(.icon) {
    width: 28px;
    height: 28px;
  }
  .role-card--developer .role-card-icon { color: #22d3ee; }
  .role-card--user .role-card-icon { color: #fbbf24; }
  .role-card--operator .role-card-icon { color: #a78bfa; }
  .role-card h3 { font-size: 1.15rem; margin: 0 0 0.5rem; color: var(--text-primary); }
  .role-card p { font-size: 0.9rem; color: var(--text-secondary); margin: 0 0 0.75rem; line-height: 1.45; flex: 1; }
  .card-arrow { margin-top: auto; padding-top: 0.5rem; font-size: 0.8rem; color: var(--accent-teal); font-weight: 500; }

  .portal-hero.fade-in-up,
  .portal-hero .fade-in-up,
  .section.fade-in-up {
    animation: portal-fade-in-up var(--motion-sections-fade_in_duration, 0.6s) ease-out both;
  }
  .role-card {
    animation: portal-fade-in-up 0.6s ease-out both;
  }
  .portal-hero .delay-1 { animation-delay: 0.08s; }
  .portal-hero .delay-2 { animation-delay: 0.16s; }
  .section-role-cards.delay-1 { animation-delay: 0.08s; }
  .role-card--developer { animation-delay: 0.12s; }
  .role-card--user { animation-delay: 0.2s; }
  .role-card--operator { animation-delay: 0.28s; }
  @keyframes portal-fade-in-up {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .role-card.role-card--developer,
  .role-card.role-card--user,
  .role-card.role-card--operator { animation: portal-fade-in-up 0.6s ease-out both; }
  @media (prefers-reduced-motion: reduce) {
    .portal-hero.fade-in-up,
    .portal-hero .fade-in-up,
    .section.fade-in-up,
    .role-card.role-card--developer,
    .role-card.role-card--user,
    .role-card.role-card--operator { animation: none; opacity: 1; transform: none; }
  }

  .back-to-site {
    color: var(--text-secondary);
    text-decoration: none;
    font-weight: 500;
    transition: color 0.2s ease;
  }
  .back-to-site:hover { color: var(--accent-teal); }
  .back-to-site:focus-visible { outline: 2px solid var(--accent-teal); outline-offset: 2px; }
  .section-back { margin-top: 2.5rem; }
  .section-back p { margin: 0; }
</style>

---
import Layout from '../../../layouts/Layout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import HubNav from '../../../components/HubNav.astro';
import '../../../styles/hub-common.css';
---

<Layout
  title="Community Hub — Testnet Portal"
  description="Boing Network testnet: user community, quests, faucet, and feedback. Qualify for user rewards."
>
  <article class="portal-page role-hub users-hub hub-page hub-community" data-hub="user">
    <script is:inline src="/portal-session.js"></script>
    <Breadcrumbs items={[{ label: 'Testnet Portal', href: '/testnet' }, { label: 'Community Hub' }]} />
    <div class="hub-page-main">
    <HubNav hub="user" current="index" />
    <div class="hub-hero fade-in-up">
      <h1>Community Hub</h1>
      <p class="lead">
        Use the faucet, complete quests, and share feedback. This hub is for <strong>community users</strong> only. Track your progress and qualify for user rewards from the Community & Grants pool. Full rules: <a href="/pdfs/TESTNET.pdf" target="_blank" rel="noopener">Testnet doc (PDF)</a>.
      </p>
      <div class="hub-ctas" id="hub-ctas">
        <a href="/testnet/register/user" class="btn btn-primary">Register as user</a>
        <a href="/testnet/sign-in" class="btn btn-secondary">Sign in</a>
        <a href="/testnet/users/dashboard" class="btn btn-secondary">Go to dashboard</a>
        <a href="/network/faucet" class="btn btn-secondary">Faucet</a>
      </div>
    </div>

    <section class="section steps-section fade-in-up delay-1">
      <h2>Your journey</h2>
      <ol class="steps-list steps-list--numbered">
        <li><strong>Register</strong> — Add your account ID on the <a href="/testnet/register/user">user registration</a> page.</li>
        <li><strong>Get testnet BOING</strong> — Use the <a href="/network/faucet">faucet</a> (one request per account per 60 seconds).</li>
        <li><strong>Complete quests</strong> — First drip, first tx, join the network, feedback, community. See the <a href="/testnet/users/quests">Quests</a> page.</li>
        <li><strong>Submit completions</strong> — Use the form on the Quests page (or Discord if the API is not yet deployed).</li>
      </ol>
    </section>

    <section class="section fade-in-up delay-2">
      <h2>Quick links</h2>
      <p><a href="/testnet/users/dashboard" class="btn btn-secondary">My Dashboard</a> · <a href="/testnet/users/community" class="btn btn-secondary">Community</a> · <a href="/testnet/users/quests" class="btn btn-secondary">Quests</a> · <a href="/network/faucet">Faucet</a> · <a href="/network/testnet">Join Testnet</a></p>
    </section>
    </div>
  </article>
</Layout>

<script is:inline src="/portal-session.js"></script>
<script define:vars={{ expectedRole: 'user' }}>
  (function () {
    var session = window.BoingPortalSession && window.BoingPortalSession.getSession();
    var authEl = document.getElementById('portal-auth');
    var hubCtas = document.getElementById('hub-ctas');
    if (session && session.role !== expectedRole) {
      var path = window.BoingPortalSession ? window.BoingPortalSession.roleAppPath(session.role) : '/testnet';
      window.location.href = path;
      return;
    }
    function renderAuth() {
      if (!authEl) return;
      if (!session) {
        authEl.innerHTML = '<a href="/testnet/sign-in" class="auth-link">Sign in</a>';
        return;
      }
      var short = window.BoingPortalSession ? window.BoingPortalSession.shortAccount(session.account_id_hex) : session.account_id_hex;
      authEl.innerHTML = 'Signed in as <span class="account-short">' + short + '</span> · <button type="button" id="portal-signout" class="auth-signout">Logout</button>';
      if (hubCtas) hubCtas.style.display = 'none';
      var so = document.getElementById('portal-signout');
      if (so) so.addEventListener('click', function () {
        if (window.BoingPortalSession && window.BoingPortalSession.logout) window.BoingPortalSession.logout();
        else { try { localStorage.removeItem('boing_portal_session'); } catch(_){} window.location.href = '/'; }
      });
    }
    renderAuth();
  })();
</script>

---
import Layout from '../layouts/Layout.astro';

const GITHUB_RELEASES_BASE = 'https://github.com/chiku524/boing.network/releases';
const GITHUB_API_RELEASES = 'https://api.github.com/repos/chiku524/boing.network/releases';

/** Fallback when API fails or no desktop-hub release exists yet (keep in sync with latest release) */
const FALLBACK_TAG = 'desktop-hub/v0.1.6';
const FALLBACK_VERSION = '0.1.6';
const FALLBACK_DOWNLOADS: { platform: string; label: string; filename: string; note?: string }[] = [
  { platform: 'Windows', label: 'Windows (x64)', filename: `Boing Network Hub_${FALLBACK_VERSION}_x64_en-US.msi`, note: 'MSI installer' },
  { platform: 'macOS', label: 'macOS (Apple Silicon)', filename: `Boing Network Hub_${FALLBACK_VERSION}_aarch64.dmg`, note: 'M1/M2/M3' },
  { platform: 'macOS', label: 'macOS (Intel)', filename: `Boing Network Hub_${FALLBACK_VERSION}_x86_64.dmg`, note: 'Intel Macs' },
  { platform: 'Linux', label: 'Debian / Ubuntu', filename: `boing-network-hub_${FALLBACK_VERSION}_amd64.deb`, note: '.deb package' },
  { platform: 'Linux', label: 'AppImage', filename: `Boing Network Hub_${FALLBACK_VERSION}_amd64.AppImage`, note: 'Portable, any distro' },
];

function directDownload(tag: string, filename: string): string {
  const segment = tag.includes('/') ? tag : `${tag}`;
  return `${GITHUB_RELEASES_BASE}/download/${segment}/${encodeURIComponent(filename)}`;
}

/** True if the asset is an OS installer we want to show (exclude .sig, .blockmap, etc.) */
function isDesktopInstaller(name: string): boolean {
  return /\.(msi|dmg|deb|AppImage|rpm)$/i.test(name);
}

function platformFromFilename(name: string): string {
  if (/\.msi$/i.test(name)) return 'Windows';
  if (/\.dmg$/i.test(name)) return 'macOS';
  if (/\.deb$/i.test(name) || /\.AppImage$/i.test(name) || /\.rpm$/i.test(name)) return 'Linux';
  return 'Asset';
}

/** Human-readable label and optional note from filename */
function readableLabelFromFilename(name: string): { label: string; note?: string } {
  if (/\.msi$/i.test(name)) return { label: 'Windows (x64)', note: 'MSI installer' };
  if (/\.dmg$/i.test(name)) {
    if (/aarch64|arm64|m1|m2|m3/i.test(name)) return { label: 'macOS (Apple Silicon)', note: 'M1/M2/M3' };
    return { label: 'macOS (Intel)', note: 'Intel Macs' };
  }
  if (/\.deb$/i.test(name)) return { label: 'Debian / Ubuntu', note: '.deb package' };
  if (/\.AppImage$/i.test(name)) return { label: 'AppImage', note: 'Portable, any Linux distro' };
  if (/\.rpm$/i.test(name)) return { label: 'Fedora / RHEL', note: '.rpm package' };
  return { label: name, note: undefined };
}

interface GitHubAsset {
  name: string;
  browser_download_url: string;
}

interface GitHubRelease {
  tag_name: string;
  name: string | null;
  published_at: string;
  assets: GitHubAsset[];
}

let hubTag = FALLBACK_TAG;
let hubVersion = FALLBACK_VERSION;
let useApiAssets = false;
let apiAssets: { platform: string; label: string; note?: string; url: string; name: string }[] = [];

try {
  const res = await fetch(GITHUB_API_RELEASES, {
    headers: { Accept: 'application/vnd.github+json', 'X-GitHub-Api-Version': '2022-11-28' },
    signal: AbortSignal.timeout(8000),
  });
  if (res.ok) {
    const releases: GitHubRelease[] = await res.json();
    const hubReleases = releases.filter((r) => r.tag_name.startsWith('desktop-hub/'));
    hubReleases.sort((a, b) => new Date(b.published_at).getTime() - new Date(a.published_at).getTime());
    const latest = hubReleases[0];
    if (latest && latest.assets && latest.assets.length > 0) {
      hubTag = latest.tag_name;
      hubVersion = latest.tag_name.replace(/^desktop-hub\/v?/i, '') || latest.tag_name;
      const installerAssets = latest.assets.filter((a) => isDesktopInstaller(a.name));
      if (installerAssets.length > 0) {
        useApiAssets = true;
        const mapped = installerAssets.map((a) => {
          const { label, note } = readableLabelFromFilename(a.name);
          return {
            platform: platformFromFilename(a.name),
            label,
            note,
            url: a.browser_download_url,
            name: a.name,
          };
        });
        // Order: Windows, macOS (Apple Silicon then Intel), Linux (deb, AppImage, rpm)
        const order = (p: string, name: string) => {
          if (p === 'Windows') return 0;
          if (p === 'macOS') return /aarch64|arm64/i.test(name) ? 1 : 2;
          if (p === 'Linux') return (/\.deb/i.test(name) ? 3 : /\.AppImage/i.test(name) ? 4 : 5);
          return 6;
        };
        apiAssets = mapped.sort((a, b) => order(a.platform, a.name) - order(b.platform, b.name));
      }
    }
  }
} catch {
  /* use fallback */
}
---

<Layout
  title="Downloads"
  description="Download Boing Network Hub — the all-in-one desktop app for Observer, Wallet, Finance, and Testnet."
  canonical="/downloads"
>
  <article class="downloads-page">
    <header class="downloads-hero full-width">
      <div class="downloads-hero-inner">
        <span class="stage-badge">Desktop</span>
        <h1 class="downloads-title">Downloads</h1>
        <p class="downloads-lead">Get the Boing Network Hub desktop app for Windows, macOS, or Linux. Pick your platform and download.</p>
      </div>
    </header>

    <section class="downloads-section full-width">
      <div class="downloads-section-inner">
        <h2 class="downloads-app-title">
          <span class="downloads-app-icon" aria-hidden="true">◇</span>
          Boing Network Hub
        </h2>
        <p class="downloads-app-desc">All-in-one desktop app (Tauri 2): Observer, Wallet, Finance, and Testnet in one window. Windows, macOS, and Linux.</p>
        <p id="downloads-hub-version" class="downloads-version">Version {hubVersion} · <a href={`${GITHUB_RELEASES_BASE}/tag/${hubTag}`} target="_blank" rel="noopener noreferrer" class="downloads-release-link">Release</a></p>

        <ul id="downloads-hub-list" class="downloads-list" role="list">
          {useApiAssets
            ? apiAssets.map((item) => (
                <li class="download-item">
                  <a href={item.url} class="download-link" download={item.name} rel="noopener noreferrer" title={item.name}>
                    <span class="download-platform">{item.platform}</span>
                    <span class="download-label">{item.label}</span>
                    {item.note && <span class="download-note">{item.note}</span>}
                    <span class="download-cta">Download</span>
                  </a>
                </li>
              ))
            : FALLBACK_DOWNLOADS.map((item) => {
                const url = directDownload(FALLBACK_TAG, item.filename);
                return (
                  <li class="download-item">
                    <a href={url} class="download-link" download={item.filename} rel="noopener noreferrer">
                      <span class="download-platform">{item.platform}</span>
                      <span class="download-label">{item.label}</span>
                      {item.note && <span class="download-note">{item.note}</span>}
                      <span class="download-cta">Download</span>
                    </a>
                  </li>
                );
              })}
        </ul>

        <p class="downloads-fallback">
          Other architectures or formats? See the <a id="downloads-release-link" href={`${GITHUB_RELEASES_BASE}/tag/${hubTag}`} target="_blank" rel="noopener noreferrer">release page</a> for all assets.
        </p>
      </div>
    </section>
  </article>
  <script define:vars={{ GITHUB_API_RELEASES: 'https://api.github.com/repos/chiku524/boing.network/releases', GITHUB_RELEASES_BASE: 'https://github.com/chiku524/boing.network/releases' }}>
    (function () {
      const versionEl = document.getElementById('downloads-hub-version');
      const listEl = document.getElementById('downloads-hub-list');
      const releaseLinkEl = document.getElementById('downloads-release-link');
      if (!versionEl || !listEl) return;

      fetch(GITHUB_API_RELEASES, {
        headers: { Accept: 'application/vnd.github+json', 'X-GitHub-Api-Version': '2022-11-28' },
        signal: AbortSignal.timeout(8000),
      })
        .then((r) => (r.ok ? r.json() : null))
        .then((releases) => {
          if (!Array.isArray(releases) || releases.length === 0) return;
          const hubReleases = releases.filter((r) => r.tag_name && r.tag_name.startsWith('desktop-hub/'));
          hubReleases.sort((a, b) => new Date(b.published_at).getTime() - new Date(a.published_at).getTime());
          const latest = hubReleases[0];
          if (!latest || !latest.assets || latest.assets.length === 0) return;

          const tag = latest.tag_name;
          const version = tag.replace(/^desktop-hub\/v?/i, '') || tag;
          const installers = latest.assets.filter((a) => /\.(msi|dmg|deb|AppImage|rpm)$/i.test(a.name));
          if (installers.length === 0) return;

          const esc = (s) => String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/"/g, '&quot;');
          const escUrl = (s) => encodeURI(String(s)).replace(/[<>"']/g, '');

          const order = (p, name) => {
            if (p === 'Windows') return 0;
            if (p === 'macOS') return /aarch64|arm64/i.test(name) ? 1 : 2;
            if (p === 'Linux') return (/\.deb/i.test(name) ? 3 : /\.AppImage/i.test(name) ? 4 : 5);
            return 6;
          };
          const platform = (name) => {
            if (/\.msi$/i.test(name)) return 'Windows';
            if (/\.dmg$/i.test(name)) return 'macOS';
            if (/\.(deb|AppImage|rpm)$/i.test(name)) return 'Linux';
            return 'Asset';
          };
          const label = (name) => {
            if (/\.msi$/i.test(name)) return { label: 'Windows (x64)', note: 'MSI installer' };
            if (/\.dmg$/i.test(name)) return /aarch64|arm64|m1|m2|m3/i.test(name) ? { label: 'macOS (Apple Silicon)', note: 'M1/M2/M3' } : { label: 'macOS (Intel)', note: 'Intel Macs' };
            if (/\.deb$/i.test(name)) return { label: 'Debian / Ubuntu', note: '.deb package' };
            if (/\.AppImage$/i.test(name)) return { label: 'AppImage', note: 'Portable, any Linux distro' };
            if (/\.rpm$/i.test(name)) return { label: 'Fedora / RHEL', note: '.rpm package' };
            return { label: name, note: undefined };
          };

          const sorted = installers
            .map((a) => ({ ...a, platform: platform(a.name), ...label(a.name) }))
            .sort((a, b) => order(a.platform, a.name) - order(b.platform, b.name));

          const releaseUrl = `${GITHUB_RELEASES_BASE}/tag/${encodeURIComponent(tag)}`;
          versionEl.innerHTML = `Version ${esc(version)} · <a href="${releaseUrl}" target="_blank" rel="noopener noreferrer" class="downloads-release-link">Release</a>`;
          if (releaseLinkEl) releaseLinkEl.href = releaseUrl;

          listEl.innerHTML = sorted
            .map(
              (a) =>
                `<li class="download-item"><a href="${escUrl(a.browser_download_url)}" class="download-link" download="${esc(a.name)}" rel="noopener noreferrer" title="${esc(a.name)}"><span class="download-platform">${esc(a.platform)}</span><span class="download-label">${esc(a.label)}</span>${a.note ? `<span class="download-note">${esc(a.note)}</span>` : ''}<span class="download-cta">Download</span></a></li>`
            )
            .join('');
        })
        .catch(() => {});
    })();
  </script>
</Layout>

<style>
  .full-width {
    width: 100%;
    max-width: 100vw;
    box-sizing: border-box;
  }
  .downloads-hero-inner,
  .downloads-section-inner {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  .downloads-hero {
    padding: 4rem 0;
    text-align: center;
    background: linear-gradient(180deg, rgba(0, 217, 255, 0.06) 0%, transparent 70%);
    border-bottom: 1px solid var(--border-color);
  }
  .downloads-hero .stage-badge,
  .downloads-hero .downloads-title,
  .downloads-hero .downloads-lead {
    opacity: 0;
    transform: translateY(16px);
    animation: downloads-hero-reveal 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  .downloads-hero .stage-badge { animation-delay: 0s; }
  .downloads-hero .downloads-title { animation-delay: 0.08s; }
  .downloads-hero .downloads-lead { animation-delay: 0.16s; }
  @keyframes downloads-hero-reveal { to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) {
    .downloads-hero .stage-badge, .downloads-hero .downloads-title, .downloads-hero .downloads-lead { animation: none; opacity: 1; transform: none; }
  }
  .stage-badge {
    display: inline-block;
    padding: 0.35rem 0.85rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #FFB800;
    background: rgba(255, 184, 0, 0.15);
    border: 1px solid rgba(255, 184, 0, 0.4);
    border-radius: 999px;
    margin-bottom: 1rem;
  }
  .downloads-title {
    font-size: clamp(2rem, 4vw, 2.75rem);
    margin: 0 0 0.5rem;
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--accent-teal);
    text-shadow: 0 0 10px rgba(0, 217, 255, 0.6);
  }
  .downloads-lead {
    font-size: 1.15rem;
    color: var(--text-secondary);
    margin: 0;
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
  }
  .downloads-section {
    padding: 3rem 0 2rem;
  }
  .downloads-app-title {
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0 0 0.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .downloads-app-icon {
    color: var(--accent-teal);
    font-size: 1.25rem;
  }
  .downloads-app-desc {
    color: var(--text-secondary);
    margin: 0 0 0.25rem;
    line-height: 1.5;
  }
  .downloads-version {
    font-size: 0.9rem;
    color: var(--text-tertiary);
    margin: 0 0 1.5rem;
  }
  .downloads-release-link {
    color: var(--accent-teal);
    text-decoration: none;
  }
  .downloads-release-link:hover {
    text-decoration: underline;
  }
  .downloads-list {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .download-item {
    margin: 0;
  }
  .download-link {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 1rem;
    padding: 1rem 1.25rem;
    background: linear-gradient(180deg, #0A1E2E 0%, #0D2E42 100%);
    border: 1px solid var(--border-color);
    border-radius: 0.75rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .download-link:hover {
    border-color: rgba(0, 217, 255, 0.5);
    box-shadow: 0 0 16px rgba(0, 217, 255, 0.12);
  }
  .download-platform {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-tertiary);
    min-width: 4.5rem;
  }
  .download-label {
    font-weight: 600;
    color: var(--text-primary);
    flex: 1;
  }
  .download-note {
    font-size: 0.85rem;
    color: var(--text-tertiary);
  }
  .download-cta {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--accent-teal);
  }
  .downloads-fallback {
    font-size: 0.9rem;
    color: var(--text-tertiary);
    margin: 0;
  }
  .downloads-fallback a {
    color: var(--accent-teal);
    text-decoration: underline;
  }
  .downloads-fallback a:hover {
    text-decoration: none;
  }
  @media (max-width: 640px) {
    .downloads-hero-inner,
    .downloads-section-inner { padding: 0 1.25rem; }
    .downloads-hero { padding: 3rem 0; }
    .downloads-section { padding: 2rem 0 3rem; }
  }
</style>

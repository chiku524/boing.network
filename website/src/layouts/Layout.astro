---
import '../styles/boing-theme.css';
import '../styles/design-tokens-cosmic.css';
import BoingCanvasBackground from '../components/BoingCanvasBackground.astro';
import BoingMascot from '../components/BoingMascot.astro';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  /** Design takeover: 'page-landing' = Aquatic-Space bg, 'page-app' = hex grid. Omit = default (animated bg). */
  pageClass?: 'page-landing' | 'page-app';
}

const { title = 'Boing Network', description = 'Boing Network — Authentic. Decentralized. Optimal. Quality-Assured. Authentic L1 blockchain built from first principles.', canonical, pageClass } = Astro.props;

const siteUrl = 'https://boing.network';
const fullTitle = title === 'Boing Network' ? 'Boing Network | Authentic. Decentralized. Optimal. Quality-Assured.' : `${title} | Boing Network`;
const path = (Astro.url.pathname || '/').replace(/\/$/, '') || '';
const pathNorm = path.replace(/^\//, '');
const isTestnetApp = pathNorm === 'testnet' || pathNorm.startsWith('testnet/');
const canonicalUrl = canonical ? `${siteUrl}${canonical.startsWith('/') ? canonical : '/' + canonical}` : `${siteUrl}${path || '/'}`;
const ogImage = `${siteUrl}/og.png`;
---

<!doctype html>
<html lang="en" class:list={[(path === '/' || path === '') && 'page-home']}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
    <link rel="icon" type="image/png" sizes="any" href="/assets/icon-only-transparent.png" />
    <link rel="shortcut icon" href="/favicon.svg?v=2" />
    <link rel="apple-touch-icon" href="/assets/icon-only-transparent.png" />

    <title>{fullTitle}</title>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Boing Network" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Additional SEO -->
    <meta name="theme-color" content="#020408" />
    <meta name="keywords" content="Boing, Boing Network, blockchain, DeFi, L1, cryptocurrency, boing.finance, decentralized finance" />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Boing Network",
      "url": siteUrl,
      "description": "Authentic. Decentralized. Optimal. Quality-Assured. Authentic L1 blockchain built from first principles.",
      "slogan": "Authentic. Decentralized. Optimal. Quality-Assured."
    })} />
  </head>
  <body class:list={[pageClass, `route-${(path || '/').replace(/^\//, '').replace(/\//g, '-') || 'index'}`, isTestnetApp && 'testnet-app']}>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <BoingCanvasBackground path={path} />
    <BoingMascot />
    <header class="site-header">
      <a href="/" class="logo">
        <img src="/assets/icon-only-transparent.png" alt="Boing" width="40" height="40" class="logo-icon" />
        <span class="gradient-text">Boing Network</span>
      </a>
      <nav class="site-nav" aria-label="Main">
        <span class="nav-main" data-testnet-hide>
          {(path === '/' || path === '') ? (
            <>
              <a href="#hero" class="nav-section">Overview</a>
              <a href="#pillars" class="nav-section">Pillars</a>
              <a href="#tokenomics" class="nav-section">Tokenomics</a>
              <a href="#roadmap" class="nav-section">Roadmap</a>
              <a href="#build" class="nav-section">Build</a>
              <a href="/testnet" class="nav-testnet">Dashboard</a>
              <a href="/resources" class="nav-section">Resources</a>
            </>
          ) : (
            <>
              <a href="/" class="nav-link">Overview</a>
              <a href="/testnet" class="nav-testnet">Dashboard</a>
              <a href="/resources" class="nav-link">Resources</a>
              <a href="/about" class="nav-link nav-link--secondary">About</a>
              <a href="/community" class="nav-link nav-link--secondary">Community</a>
            </>
          )}
        </span>
        <span class="nav-testnet-only" data-testnet-show>
          <a href="/testnet">Testnet Portal</a>
          <a href="/" class="testnet-logout" id="testnet-logout">Logout — Back to website</a>
        </span>
      </nav>
    </header>
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
    <footer class="site-footer testnet-footer" data-testnet-show>
      <p>Boing Testnet — Register and sign in to access your hub.</p>
      <div class="footer-links">
        <a href="/">Back to Boing Network</a>
        <a href="/testnet">Portal</a>
      </div>
    </footer>
    <footer class="site-footer site-footer-main" data-testnet-hide>
      <p>Boing Network — Authentic. Decentralized. Optimal. Quality-Assured. <strong>Currently in Testnet.</strong></p>
      <div class="footer-links">
        <a href="/testnet">Dashboard</a>
        <a href="/resources">Resources</a>
        <a href="/network/testnet">Join Testnet</a>
        <a href="/network/faucet">Faucet</a>
        <a href="https://github.com/chiku524/boing.network" target="_blank" rel="noopener">GitHub</a>
        <a href="https://boing.finance" target="_blank" rel="noopener">boing.finance</a>
        <a href="/docs">Documentation</a>
      </div>
    </footer>
    <script is:inline>
      (function() {
        var p = window.location.pathname.replace(/\/$/, '') || '/';
        var isTestnet = p === '/testnet' || p.indexOf('/testnet/') === 0;
        if (isTestnet) document.body.classList.add('testnet-app');
        document.getElementById('testnet-logout')?.addEventListener('click', function(e) {
          e.preventDefault();
          try { localStorage.removeItem('boing_portal_session'); } catch(_){}
          window.location.href = '/';
        });
      })();
    </script>
  </body>
</html>

<style is:global>
  * { box-sizing: border-box; }

  html {
    font-family: var(--font-sans);
    background: var(--bg-primary);
    color: var(--text-primary);
    line-height: 1.6;
  }

  body {
    margin: 0;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    position: relative;
  }

  main { flex: 1; position: relative; z-index: 1; padding-top: 4.5rem; }

  /* Skip link: visible on focus for keyboard users */
  .skip-link {
    position: absolute;
    top: -100px;
    left: 1rem;
    z-index: 100;
    padding: 0.75rem 1rem;
    background: var(--bg-primary);
    color: var(--accent-teal);
    font-weight: 600;
    border: 2px solid var(--accent-teal);
    border-radius: 6px;
    text-decoration: none;
    transition: top 0.2s ease;
  }
  .skip-link:focus {
    top: 1rem;
    outline: none;
    box-shadow: 0 0 0 4px rgba(34, 211, 238, 0.4);
  }

  /* Consistent focus-visible for interactive elements */
  a:focus-visible,
  button:focus-visible,
  input:focus-visible,
  select:focus-visible,
  textarea:focus-visible {
    outline: 2px solid var(--accent-teal);
    outline-offset: 2px;
  }
  .site-header nav a:focus-visible {
    outline-offset: 4px;
  }

  /* Homepage: hide live BG until Genesis Block intro completes (intro script sets opacity) */
  html.page-home .boing-canvas-bg {
    opacity: 0;
    transition: opacity 1s ease;
  }

  a {
    color: var(--accent-neon);
    text-decoration: none;
    transition: color 0.2s;
  }

  a:hover {
    color: var(--accent-purple);
  }

  code {
    font-family: var(--font-mono);
    background: var(--bg-tertiary);
    padding: 0.2em 0.4em;
    border-radius: 6px;
    font-size: 0.9em;
  }

  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 30;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
    padding: 1rem 2rem;
    border-bottom: 1px solid var(--border-color);
    background: rgba(10, 14, 26, 0.85);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    box-shadow: 0 4px 20px var(--shadow);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    font-size: 1.25rem;
    text-decoration: none;
  }
  .logo-icon {
    flex-shrink: 0;
    display: block;
    width: 40px;
    height: 40px;
    object-fit: contain;
    filter: drop-shadow(0 0 6px var(--glow-cyan-subtle));
  }

  .logo:hover .logo-icon {
    filter: drop-shadow(0 0 10px var(--glow-cyan));
  }

  .site-header nav {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .site-header nav a {
    color: var(--text-secondary);
    font-weight: 500;
    padding: 0.35rem 0;
    line-height: 1.5;
    display: inline-block;
  }

  .site-header nav a:hover,
  .site-header nav a.active {
    color: var(--accent-teal);
  }

  /* Testnet: far right, distinct color (amber/gold) */
  .site-header nav a.nav-testnet {
    margin-left: auto;
    color: #f59e0b;
    font-weight: 600;
  }
  .site-header nav a.nav-testnet:hover {
    color: #fbbf24;
  }
  .site-header nav a.nav-link--secondary {
    color: var(--text-tertiary);
    font-size: 0.9rem;
  }
  .site-header nav a.nav-link--secondary:hover {
    color: var(--accent-teal);
  }

  /* Testnet app shell: show only testnet nav/footer when body has .testnet-app */
  body.testnet-app [data-testnet-hide] { display: none !important; }
  body.testnet-app [data-testnet-show] { display: revert !important; }
  body.testnet-app .site-nav .nav-testnet-only { display: inline-flex !important; }
  body.testnet-app .testnet-footer { display: block !important; }
  body:not(.testnet-app) [data-testnet-show] { display: none !important; }
  body:not(.testnet-app) .site-nav [data-testnet-hide] { display: inline-flex !important; }
  body:not(.testnet-app) .site-footer-main { display: block !important; }
  .site-nav .nav-main { display: inline-flex; align-items: center; gap: 1rem; flex-wrap: wrap; }
  .site-nav .nav-testnet-only { display: inline-flex; align-items: center; gap: 1rem; flex-wrap: wrap; }
  body.page-home .site-footer-main { display: none !important; }

  /* Testnet app: logout link */
  .site-header nav a.testnet-logout {
    margin-left: auto;
    color: var(--text-tertiary);
  }
  .site-header nav a.testnet-logout:hover {
    color: var(--accent-teal);
  }

  /* Cosmic Foundation: primary CTA = violet → cyan gradient */
  .site-header nav a.nav-cta {
    padding: 0.35rem 0.75rem;
    border-radius: var(--radius-pill, 999px);
    font-weight: 600;
    color: white;
    background: linear-gradient(135deg, var(--accent-teal), var(--accent-cyan));
    border: none;
    box-shadow: 0 0 20px rgba(124, 58, 237, 0.3);
    transition: all var(--motion-transition);
  }

  .site-header nav a.nav-cta:hover {
    color: white;
    transform: translateY(-1px);
    box-shadow: 0 0 28px rgba(124, 58, 237, 0.5);
  }

  /* Shared Join Testnet / primary CTA (hero, banners) — Cosmic gradient */
  .btn-testnet {
    color: white !important;
    background: linear-gradient(135deg, var(--accent-teal), var(--accent-cyan)) !important;
    border: none !important;
    font-weight: 600;
    box-shadow: 0 0 20px rgba(124, 58, 237, 0.3);
    transition: all var(--motion-transition);
  }
  .btn-testnet:hover {
    color: white !important;
    transform: translateY(-1px);
    box-shadow: 0 0 28px rgba(124, 58, 237, 0.5);
  }

  @media (prefers-reduced-motion: reduce) {
    .site-header nav a.nav-cta:hover,
    .btn-testnet:hover { transform: none; }
  }

  .site-footer {
    position: relative;
    z-index: 1;
    padding: 2rem;
    border-top: 1px solid var(--border-color);
    text-align: center;
    color: var(--text-tertiary);
    font-size: 0.875rem;
  }

  .site-footer a {
    color: var(--accent-neon);
  }

  .footer-links {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 1rem 1.5rem;
    margin-top: 0.5rem;
  }

  @media print {
    .skip-link,
    .boing-canvas-bg,
    .boing-mascot {
      display: none !important;
    }
    .site-header {
      position: relative !important;
      background: #f5f5f5 !important;
      border-bottom: 1px solid #ddd !important;
    }
    main {
      padding-top: 0 !important;
    }
    a[href]::after {
      content: none;
    }
  }

  @media (max-width: 640px) {
    .site-header {
      flex-direction: column;
      align-items: flex-start;
    }
    .site-header nav {
      width: 100%;
    }
  }
</style>

---
import '../styles/boing-design-kit.css';
import '../styles/boing-theme.css';
import '../styles/design-tokens-cosmic.css';
import '../styles/boing-loader.css';
import BoingCanvasBackground from '../components/BoingCanvasBackground.astro';
import BoingMascot from '../components/BoingMascot.astro';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  /** Design takeover: 'page-landing' = Aquatic-Space bg, 'page-app' = hex grid. Omit = default (animated bg). */
  pageClass?: 'page-landing' | 'page-app';
}

const { title = 'Boing Network', description = 'Boing Network — Authentic. Decentralized. Optimal. Quality-Assured. Authentic L1 blockchain built from first principles.', canonical, pageClass } = Astro.props;

const siteUrl = 'https://boing.network';
const fullTitle = title === 'Boing Network' ? 'Boing Network | Authentic. Decentralized. Optimal. Quality-Assured.' : `${title} | Boing Network`;
const path = (Astro.url.pathname || '/').replace(/\/$/, '') || '';
const pathNorm = path.replace(/^\//, '');
const isTestnetApp = pathNorm === 'testnet' || pathNorm.startsWith('testnet/');
const canonicalUrl = canonical ? `${siteUrl}${canonical.startsWith('/') ? canonical : '/' + canonical}` : `${siteUrl}${path || '/'}`;
const ogImage = `${siteUrl}/og.png`;
const isAuthPage = /^testnet\/(sign-in|register|set-password)(\/|$)/.test(pathNorm);
const noindex = isAuthPage;
---

<!doctype html>
<html lang="en" class:list={[(path === '/' || path === '') && 'page-home']}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=4" />
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/assets/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/assets/logo-192.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/assets/icon-only-transparent.png" />
    <link rel="shortcut icon" href="/favicon.svg?v=4" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <title>{fullTitle}</title>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Boing Network — The DeFi that always bounces back!" />
    <meta property="og:site_name" content="Boing Network" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="Boing Network — The DeFi that always bounces back!" />

    <!-- Additional SEO -->
    <meta name="theme-color" content="#0A1E2E" />
    <meta name="keywords" content="Boing, Boing Network, blockchain, DeFi, L1, cryptocurrency, boing.finance, decentralized finance" />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Boing Network",
      "url": siteUrl,
      "description": "Authentic. Decentralized. Optimal. Quality-Assured. Authentic L1 blockchain built from first principles.",
      "slogan": "The DeFi that always bounces back!",
      "logo": `${siteUrl}/assets/icon-only-transparent.png`,
      "image": ogImage
    })} />
  </head>
  <body class:list={[pageClass, `route-${(path || '/').replace(/^\//, '').replace(/\//g, '-') || 'index'}`, isTestnetApp && 'testnet-app']}>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <BoingCanvasBackground path={path} />
    <BoingMascot />
    <header class="site-header bg-ocean-blue/95 backdrop-blur-md border-b border-cyan-transparent shadow-md">
      <a href="/" class="logo flex items-center gap-2 no-underline">
        <img src="/logo.svg" alt="Boing" width="40" height="40" class="logo-icon flex-shrink-0" />
        <span class="font-display font-extrabold text-xl text-neon-cyan">Boing Network</span>
      </a>
      <nav class="site-nav" aria-label="Main">
        {path === '/' || path === '' ? (
          <>
            <a href="#hero" class="nav-section">Overview</a>
            <a href="#pillars" class="nav-section">Pillars</a>
            <a href="#tokenomics" class="nav-section">Tokenomics</a>
            <a href="#roadmap" class="nav-section">Roadmap</a>
            <a href="#build" class="nav-section">Build</a>
            <a href="/testnet" class="nav-testnet">Dashboard</a>
            <a href="/resources" class="nav-section">Resources</a>
            <a href="/downloads" class="nav-section">Downloads</a>
          </>
        ) : isTestnetApp ? (
          <>
            <a href="/testnet" class="nav-testnet" data-testnet-nav="dashboard" id="nav-testnet-dashboard">Dashboard</a>
            <span id="nav-testnet-hub-links" class="nav-hub-links" style="display: none;" aria-label="Hub pages">
              <a href="/testnet/developers/resources" data-testnet-hub-link data-hub="developer">Resources</a>
              <a href="/testnet/developers/community" data-testnet-hub-link data-hub="developer">Community</a>
              <a href="/testnet/developers/dashboard" data-testnet-hub-link data-hub="developer">My Dashboard</a>
              <a href="/testnet/users/community" data-testnet-hub-link data-hub="user">Community</a>
              <a href="/testnet/users/quests" data-testnet-hub-link data-hub="user">Quests</a>
              <a href="/testnet/users/dashboard" data-testnet-hub-link data-hub="user">My Dashboard</a>
              <a href="/testnet/operators/dashboard" data-testnet-hub-link data-hub="operator">My Dashboard</a>
              <a href="/testnet/operators/leaderboard" data-testnet-hub-link data-hub="operator">Leaderboard</a>
              <a href="/testnet/operators/resources" data-testnet-hub-link data-hub="operator">Resources</a>
            </span>
            <a href="/testnet/developers" data-testnet-nav="developers">Developers</a>
            <a href="/testnet/users" data-testnet-nav="users">Users</a>
            <a href="/testnet/operators" data-testnet-nav="operators">Operators</a>
            <a href="/testnet/register" data-testnet-nav="register">Register</a>
            <span class="nav-site-sep" id="nav-testnet-sep" aria-hidden="true">·</span>
            <a href="/resources" class="nav-site-link" id="nav-testnet-site-resources">Resources</a>
            <span id="portal-auth" class="portal-auth-nav"></span>
            <a href="/" class="testnet-logout">Back to website</a>
          </>
        ) : (
          <>
            <a href="/" class="nav-link">Overview</a>
            <a href="/testnet" class="nav-testnet">Dashboard</a>
            <a href="/resources" class="nav-link">Resources</a>
            <a href="/downloads" class="nav-link">Downloads</a>
            <a href="/about" class="nav-link nav-link--secondary">About</a>
            <a href="/community" class="nav-link nav-link--secondary">Community</a>
          </>
        )}
      </nav>
    </header>
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
    <footer class="site-footer testnet-footer" data-testnet-show>
      <p>Boing Testnet — Register and sign in to access your hub.</p>
      <div class="footer-links">
        <a href="/">Back to Boing Network</a>
        <a href="/testnet">Portal</a>
      </div>
    </footer>
    <footer class="site-footer site-footer-main" data-testnet-hide>
      <p>Boing Network — Authentic. Decentralized. Optimal. Quality-Assured. <strong>Currently in Testnet.</strong></p>
      <div class="footer-links">
        <a href="/testnet">Dashboard</a>
        <a href="/resources">Resources</a>
        <a href="/downloads">Downloads</a>
        <a href="/network/testnet">Join Testnet</a>
        <a href="/network/faucet">Faucet</a>
        <a href="https://boing.observer" target="_blank" rel="noopener">Explorer</a>
        <a href="https://boing.express" target="_blank" rel="noopener">Wallet</a>
        <a href="https://github.com/chiku524/boing.network" target="_blank" rel="noopener">GitHub</a>
        <a href="https://boing.finance" target="_blank" rel="noopener">boing.finance</a>
        <a href="/docs">Documentation</a>
      </div>
    </footer>
    <script is:inline>
      (function() {
        var p = window.location.pathname.replace(/\/$/, '') || '/';
        var isTestnet = p === '/testnet' || p.indexOf('/testnet/') === 0;
        if (isTestnet) document.body.classList.add('testnet-app');
        document.querySelector('.site-header a.testnet-logout')?.addEventListener('click', function(e) {
          e.preventDefault();
          try { localStorage.removeItem('boing_portal_session'); } catch(_){}
          window.location.href = '/';
        });
      })();
    </script>
    <script is:inline src="/portal-session.js"></script>
    <script is:inline>
      (function() {
        var p = window.location.pathname.replace(/\/$/, '') || '/';
        if (p !== '/testnet' && p.indexOf('/testnet/') !== 0) return;
        var session = window.BoingPortalSession && window.BoingPortalSession.getSession();
        var dashboardLink = document.getElementById('nav-testnet-dashboard');
        var hubLinksContainer = document.getElementById('nav-testnet-hub-links');
        var navItems = document.querySelectorAll('.site-nav [data-testnet-nav]');
        if (dashboardLink) dashboardLink.href = (window.BoingPortalSession && session) ? (window.BoingPortalSession.roleAppPath(session.role) || '/testnet') : '/testnet';
        if (session) {
          if (dashboardLink) dashboardLink.style.display = 'none';
          if (hubLinksContainer) hubLinksContainer.style.display = 'none';
          var sep = document.getElementById('nav-testnet-sep');
          if (sep) sep.style.display = 'none';
          navItems.forEach(function(el) {
            el.style.display = 'none';
          });
        } else {
          if (dashboardLink) dashboardLink.style.display = '';
          if (hubLinksContainer) hubLinksContainer.style.display = 'none';
          var sep = document.getElementById('nav-testnet-sep');
          if (sep) sep.style.display = '';
          navItems.forEach(function(el) {
            var role = el.getAttribute('data-testnet-nav');
            if (role === 'developers' || role === 'users' || role === 'operators') { el.style.display = ''; return; }
            if (role === 'register') { el.style.display = ''; return; }
            if (role === 'dashboard') { el.style.display = ''; return; }
          });
        }
      })();
    </script>
  </body>
</html>

<style is:global>
  * { box-sizing: border-box; }

  html {
    font-family: var(--font-sans);
    background: var(--bg-primary);
    color: var(--text-primary);
    line-height: 1.6;
  }

  body {
    margin: 0;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    position: relative;
  }

  main { flex: 1; position: relative; z-index: 1; padding-top: 4.5rem; }
  body.testnet-app main { padding-top: 6rem; }
  body.testnet-app .breadcrumbs { margin-top: 0.5rem; }

  /* Skip link: visible on focus for keyboard users */
  .skip-link {
    position: absolute;
    top: -100px;
    left: 1rem;
    z-index: 100;
    padding: 0.75rem 1rem;
    background: var(--bg-primary);
    color: var(--accent-teal);
    font-weight: 600;
    border: 2px solid var(--accent-teal);
    border-radius: 6px;
    text-decoration: none;
    transition: top 0.2s ease;
  }
  .skip-link:focus {
    top: 1rem;
    outline: none;
    box-shadow: 0 0 0 4px rgba(34, 211, 238, 0.4);
  }

  /* Consistent focus-visible for interactive elements */
  a:focus-visible,
  button:focus-visible,
  input:focus-visible,
  select:focus-visible,
  textarea:focus-visible {
    outline: 2px solid var(--accent-teal);
    outline-offset: 2px;
  }
  .site-header nav a:focus-visible {
    outline-offset: 4px;
  }

  /* Homepage: hide live BG until Genesis Block intro completes (intro script sets opacity) */
  html.page-home .boing-canvas-bg {
    opacity: 0;
    transition: opacity 1s ease;
  }

  a {
    color: var(--accent-neon);
    text-decoration: none;
    transition: color 0.2s;
  }

  a:hover {
    color: var(--accent-purple);
  }

  code {
    font-family: var(--font-mono);
    background: var(--bg-tertiary);
    padding: 0.2em 0.4em;
    border-radius: 6px;
    font-size: 0.9em;
  }

  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 30;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem 1rem;
    padding: 0.875rem 1.5rem;
  }
  @media (min-width: 768px) {
    .site-header { padding: 0.875rem 2rem; }
  }
  body.testnet-app .site-header {
    padding: 0.75rem 1.5rem;
    gap: 0.5rem 1rem;
  }
  @media (min-width: 768px) {
    body.testnet-app .site-header { padding: 0.75rem 2rem; }
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    font-size: 1.25rem;
    text-decoration: none;
  }
  .logo-icon {
    flex-shrink: 0;
    display: block;
    width: 40px;
    height: 40px;
    object-fit: contain;
    filter: drop-shadow(0 0 6px var(--glow-cyan-subtle));
  }

  .logo:hover .logo-icon {
    filter: drop-shadow(0 0 10px var(--glow-cyan));
  }

  .site-header nav {
    display: flex;
    align-items: center;
    gap: 0.75rem 1rem;
    flex-wrap: wrap;
  }
  body.testnet-app .site-header nav {
    gap: 0.5rem 0.75rem;
  }
  .site-header nav a {
    color: var(--text-primary);
    font-family: var(--font-sans);
    font-weight: 500;
    padding: 0.35rem 0.5rem;
    line-height: 1.5;
    display: inline-block;
    white-space: nowrap;
    transition: color 0.2s ease;
  }
  body.testnet-app .site-header nav a {
    padding: 0.4rem 0.35rem;
  }

  .site-header nav a:hover,
  .site-header nav a.active {
    color: var(--accent-teal);
  }
  .site-header nav a.nav-section.active {
    color: var(--accent-teal);
    border-bottom: 2px solid var(--accent-teal);
  }

  /* Testnet: far right, distinct color (amber/gold) */
  .site-header nav a.nav-testnet {
    margin-left: auto;
    color: #f59e0b;
    font-weight: 600;
  }
  .site-header nav a.nav-testnet:hover {
    color: #fbbf24;
  }
  .site-header nav a.nav-link--secondary {
    color: var(--text-tertiary);
    font-size: 0.9rem;
  }
  .site-header nav a.nav-link--secondary:hover {
    color: var(--accent-teal);
  }

  /* Testnet app: show testnet footer; main nav already includes testnet links from Layout */
  body.testnet-app [data-testnet-show] { display: revert !important; }
  body.testnet-app [data-testnet-hide] { display: none !important; }
  body.testnet-app .testnet-footer { display: block !important; }
  body.testnet-app .site-footer-main { display: none !important; }
  body:not(.testnet-app) [data-testnet-show] { display: none !important; }
  body:not(.testnet-app) .site-footer-main { display: block !important; }
  body.page-home .site-footer-main { display: none !important; }
  .site-nav { display: flex; align-items: center; gap: 0.75rem 1rem; flex-wrap: wrap; }
  .nav-hub-links {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem 0.75rem;
    flex-wrap: wrap;
  }
  .nav-hub-links a { white-space: nowrap; }
  .nav-site-sep { color: var(--text-tertiary); font-weight: 300; pointer-events: none; margin: 0 0.1rem; }
  .site-header nav a.nav-site-link { color: var(--text-tertiary); font-size: 0.9rem; }
  .site-header nav a.nav-site-link:hover { color: var(--accent-teal); }

  /* Testnet app: logout link + portal-auth in header */
  .site-header nav a.testnet-logout {
    margin-left: auto;
    color: var(--text-tertiary);
  }
  .site-header nav a.testnet-logout:hover {
    color: var(--accent-teal);
  }
  .portal-auth-nav {
    font-size: 0.9rem;
    color: var(--text-secondary);
  }
  .portal-auth-nav .account-short {
    font-family: var(--font-mono);
    color: var(--accent-teal);
  }
  .portal-auth-nav a {
    color: var(--accent-teal);
  }
  .portal-auth-nav .auth-signout {
    background: none;
    border: none;
    color: var(--text-tertiary);
    cursor: pointer;
    font-size: inherit;
    padding: 0;
  }
  .portal-auth-nav .auth-signout:hover {
    color: var(--accent-teal);
  }

  /* Boing Design Kit: primary CTA = neon cyan */
  .site-header nav a.nav-cta {
    padding: 0.35rem 0.75rem;
    border-radius: 8px;
    font-weight: 600;
    font-family: var(--font-display);
    color: #0A1E2E;
    background: var(--accent-teal);
    border: none;
    box-shadow: 0 0 20px rgba(0, 217, 255, 0.6);
    transition: all 0.2s ease;
  }

  .site-header nav a.nav-cta:hover {
    color: #0A1E2E;
    transform: translateY(-2px);
    box-shadow: 0 0 30px rgba(0, 217, 255, 0.8);
  }

  /* Shared Join Testnet / primary CTA (hero, banners) — Design Kit */
  .btn-testnet {
    color: #0A1E2E !important;
    background: var(--accent-teal) !important;
    border: none !important;
    font-weight: 600;
    font-family: var(--font-display);
    box-shadow: 0 0 20px rgba(0, 217, 255, 0.6);
    transition: all 0.2s ease;
  }
  .btn-testnet:hover {
    color: #0A1E2E !important;
    transform: translateY(-2px);
    box-shadow: 0 0 30px rgba(0, 217, 255, 0.8);
  }

  @media (prefers-reduced-motion: reduce) {
    .site-header nav a.nav-cta:hover,
    .btn-testnet:hover { transform: none; }
  }

  .site-footer {
    position: relative;
    z-index: 1;
    padding: 2rem;
    border-top: 1px solid var(--border-color);
    text-align: center;
    color: var(--text-tertiary);
    font-size: 0.875rem;
    background: var(--bg-primary);
  }

  .site-footer a {
    color: var(--accent-teal);
  }
  .site-footer a:hover {
    color: var(--accent-electric);
  }

  .footer-links {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 1rem 1.5rem;
    margin-top: 0.5rem;
  }

  @media print {
    .skip-link,
    .boing-canvas-bg,
    .boing-mascot {
      display: none !important;
    }
    .site-header {
      position: relative !important;
      background: #f5f5f5 !important;
      border-bottom: 1px solid #ddd !important;
    }
    main {
      padding-top: 0 !important;
    }
    a[href]::after {
      content: none;
    }
  }

  @media (max-width: 640px) {
    .site-header {
      flex-direction: column;
      align-items: flex-start;
    }
    .site-header nav {
      width: 100%;
    }
  }
</style>

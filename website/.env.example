# Testnet configuration for the website (faucet default RPC and bootnodes).
# Copy to .env and set values before building for production.
# Used by website/src/config/testnet.ts at build time.

# Public testnet RPC URL — faucet page will use this as the default.
# Example: https://testnet-rpc.boing.network/
PUBLIC_TESTNET_RPC_URL=http://127.0.0.1:8545

# Comma-separated bootnode multiaddrs (optional).
# Example: /ip4/1.2.3.4/tcp/4001,/ip4/5.6.7.8/tcp/4001
# If not set, the list in src/config/testnet.ts is used.
# PUBLIC_BOOTNODES=

{
  "name": "boing-network-website",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "generate:brand-raster": "node scripts/generate-brand-raster.mjs",
    "verify:site-layout": "node scripts/verify-site-pages-use-layout.mjs",
    "prebuild": "npm run generate:brand-raster && npm run verify:site-layout",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "build:pdfs": "node scripts/generate-pdfs.js",
    "networks:release-sql": "node scripts/network-listings-release-sql.mjs",
    "deploy": "npm run build && npx wrangler pages deploy dist --project-name=boing-network"
  },
  "dependencies": {
    "@astrojs/tailwind": "^6.0.2",
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^2.0.1",
    "astro": "^5.18.1",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "md-to-pdf": "^5.2.5",
    "sharp": "^0.34.5",
    "wrangler": "^4.76.0"
  }
}
